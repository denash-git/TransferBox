backup_restore_menu() {
    import_modules() { :; } # Dummy
    import tarfile 2>/dev/null || :
    import datetime 2>/dev/null || :
    
    while True; do
        local options=(
            "Создать бэкап настроек"
            "Восстановить из последнего бэкапа"
            "Назад"
        )
        select_menu "Бэкап и Восстановление" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            print_header "Создание резервной копии"
            local backup_dir="/opt/transferbox/backups"
            
            # Run creation in python helper
            python3 -c "
import os, tarfile, datetime
backup_dir = '$backup_dir'
os.makedirs(backup_dir, exist_ok=True)
timestamp = datetime.datetime.now().strftime('%Y%m%d_%H%M%S')
backup_filename = f'transferbox_backup_{timestamp}.tar.gz'
backup_path = os.path.join(backup_dir, backup_filename)

files_to_backup = []
paths = ['/opt/transferbox/users.json', '/opt/transferbox/instance.env']
for p in paths:
    if os.path.exists(p):
        files_to_backup.append(p)

if not files_to_backup:
    print('ERROR: No files to backup')
else:
    try:
        with tarfile.open(backup_path, 'w:gz') as tar:
            for p in files_to_backup:
                tar.add(p, arcname=os.path.basename(p))
        print(f'SUCCESS:{backup_path}')
    except Exception as e:
        print(f'ERROR:{e}')
" > /tmp/backup_res.txt
            
            local res
            res=$(cat /tmp/backup_res.txt)
            if [[ "$res" == SUCCESS:* ]]; then
                local path="${res#SUCCESS:}"
                echo ""
                center_print "${GREEN}✓ Бэкап успешно создан!${RESET}"
                center_print "Файл сохранен: ${BOLD}${path}${RESET}"
                center_print "Скачайте этот файл на свой компьютер для надежного хранения."
            else
                echo ""
                center_print "${RED}✗ Ошибка создания бэкапа: ${res#ERROR:}${RESET}"
            fi
            rm -f /tmp/backup_res.txt
            pause
            
        elif [ "$choice" -eq 1 ]; then
            print_header "Восстановление из последнего бэкапа"
            local backup_dir="/opt/transferbox/backups"
            
            # Find latest in python
            python3 -c "
import os, glob, datetime, tarfile
backup_dir = '$backup_dir'
backup_files = glob.glob(os.path.join(backup_dir, 'transferbox_backup_*.tar.gz'))
if not backup_files:
    print('ERROR: No backup files found')
else:
    backup_files.sort(key=os.path.getmtime, reverse=True)
    latest_backup = backup_files[0]
    mtime = os.path.getmtime(latest_backup)
    file_date = datetime.datetime.fromtimestamp(mtime).strftime('%Y-%m-%d %H:%M:%S')
    print(f'FOUND:{latest_backup}|{file_date}')
" > /tmp/restore_find.txt
            
            local res
            res=$(cat /tmp/restore_find.txt)
            rm -f /tmp/restore_find.txt
            
            if [[ "$res" == ERROR:* ]]; then
                echo ""
                center_print "${RED}✗ Ошибка: В папке $backup_dir не найдено файлов бэкапов!${RESET}"
                pause
                continue
            fi
            
            # Extract path and date
            IFS='|' read -r latest_backup_info file_date <<< "${res#FOUND:}"
            local latest_filename
            latest_filename=$(basename "$latest_backup_info")
            
            echo -e "  Найден последний файл бэкапа:"
            echo -e "  • Имя:  ${BOLD}${latest_filename}${RESET}"
            echo -e "  • Дата: ${file_date}"
            draw_line "─" "$BLUE"
            echo ""
            
            local confirm
            read_prompt "Восстановить настройки из этого файла? Текущие данные будут перезаписаны! [y/N]: " confirm
            if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
                echo ""
                center_print "Операция отменена."
                pause
                continue
            fi
            
            echo -e "\n  [*] Восстановление файлов..."
            python3 -c "
import tarfile
try:
    with tarfile.open('$latest_backup_info', 'r:gz') as tar:
        tar.extractall(path='/opt/transferbox')
    print('SUCCESS')
except Exception as e:
    print('ERROR:', e)
" > /tmp/restore_extract.txt
            
            local ext_res
            ext_res=$(cat /tmp/restore_extract.txt)
            rm -f /tmp/restore_extract.txt
            
            if [ "$ext_res" == "SUCCESS" ]; then
                # Восстанавливаем состояния служб и устанавливаем их при отсутствии
                if [ -f "/opt/transferbox/instance.env" ]; then
                    source /opt/transferbox/instance.env
                fi
                
                # Восстановление Mieru
                local m_enabled="${MIERU_ENABLED:-false}"
                if [ "$m_enabled" == "true" ]; then
                    if [ ! -f "/usr/bin/mita" ]; then
                        echo -e "  [*] Обнаружена конфигурация Mieru. Автоматическая установка..."
                        install_mieru
                    else
                        echo -e "  [*] Включение службы Mieru..."
                        systemctl enable --now mita >/dev/null 2>&1 || true
                    fi
                else
                    if [ -f "/usr/bin/mita" ]; then
                        echo -e "  [*] Отключение службы Mieru..."
                        systemctl disable --now mita >/dev/null 2>&1 || true
                    fi
                fi
                
                # Восстановление NetBird
                local nb_key="${NETBIRD_SETUP_KEY:-}"
                if [ ! -z "$nb_key" ]; then
                    if ! command -v netbird &>/dev/null; then
                        echo -e "  [*] Обнаружена конфигурация NetBird. Автоматическая установка..."
                        export SKIP_UI_APP=true
                        if curl -fsSL https://pkgs.netbird.io/install.sh | sh; then
                            systemctl enable --now netbird >/dev/null 2>&1 || true
                        fi
                    fi
                    if command -v netbird &>/dev/null; then
                        echo -e "  [*] Подключение NetBird..."
                        local nb_url="${NETBIRD_MANAGEMENT_URL:-}"
                        local cmd="netbird up --setup-key $nb_key"
                        if [ ! -z "$nb_url" ]; then
                            cmd="$cmd --management-url $nb_url"
                        fi
                        eval "$cmd" || true
                    fi
                fi
                
                # Восстановление sing-box
                systemctl enable --now sing-box >/dev/null 2>&1 || true
                
                echo -e "  [*] Пересборка конфигураций и перезапуск служб..."
                python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
success, msg = validate_and_restart()
if success:
    print('SUCCESS')
else:
    print('ERROR:', msg)
" > /tmp/restore_apply.txt
                
                local apply_res
                apply_res=$(cat /tmp/restore_apply.txt)
                rm -f /tmp/restore_apply.txt
                
                if [ "$apply_res" == "SUCCESS" ]; then
                    echo ""
                    center_print "${GREEN}✓ Настройки успешно восстановлены и применены!${RESET}"
                    center_print "Все службы запущены и функционируют на восстановленных данных."
                else
                    echo ""
                    center_print "${RED}✗ Ошибка при применении восстановленных настроек: ${apply_res#ERROR:}${RESET}"
                fi
            else
                echo ""
                center_print "${RED}✗ Ошибка при распаковке архива: ${ext_res#ERROR:}${RESET}"
            fi
            pause
        elif [ "$choice" -eq 2 ] || [ "$choice" -eq -1 ]; then
            return 0
        fi
    done
}

