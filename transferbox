        echo -e "  * –£—Б—В–∞–љ–Њ–≤–Ї–∞ deb-–њ–∞–Ї–µ—В–∞..."
        if dpkg -i "$deb_file" >/dev/null 2>&1; then
            echo -e "  ${GREEN}вЬУ sing-box —Г—Б–њ–µ—И–љ–Њ —Г—Б—В–∞–љ–Њ–≤–ї–µ–љ/–Њ–±–љ–Њ–≤–ї–µ–љ.${RESET}"
            rm -f "$deb_file"
            
