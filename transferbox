    [ -z "$iface" ] && iface="eth0"
    
    while true; do
        # –°—З–Є—В—Л–≤–∞–љ–Є–µ CPU stats 1
        local cpu_stat1
        cpu_stat1=$(grep '^cpu ' /proc/stat)
        local stats1=($cpu_stat1)
