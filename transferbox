settings_menu() {
    while true; do
        if [ -f "/opt/transferbox/instance.env" ]; then
            source /opt/transferbox/instance.env
        fi
        local domain="${DOMAIN:-не задан}"
        local email="${ADMIN_EMAIL:-не задан (анонимный SSL)}"
        [ -z "$email" ] && email="не задан (анонимный SSL)"
        local template="${FAKE_SITE_TEMPLATE:-aether}"
        local vless_ws="${VLESS_WS_PATH:-/}"
        local vless_grpc="${VLESS_GRPC_SERVICE:-(пусто)}"
        [ -z "$vless_grpc" ] && vless_grpc="(пусто)"
        local vless_xhttp="${VLESS_XHTTP_PATH:-/xhttp}"
        
        local bbr_status="${RED}отключен${RESET}"
        if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q "bbr"; then
            bbr_status="${GREEN}активен${RESET}"
        fi
        
        clear_screen
        print_header "Настройки"
        echo -e "  Текущая конфигурация:"
        echo -e "  • Домен:             $domain"
        echo -e "  • Email Let's Encrypt: $email"
        echo -e "  • Шаблон сайта:      $template"
        echo -e "  • Путь VLESS WS:     $vless_ws"
        echo -e "  • Сервис VLESS gRPC:  $vless_grpc"
        echo -e "  • Путь VLESS XHTTP:  $vless_xhttp"
        echo -e "  • TCP BBR:           $bbr_status"
        draw_line "─" "$BLUE"
        
        local options=(
            "Изменить Домен и Email"
            "Выбрать шаблон маскировочного сайта"
            "Настроить пути VLESS"
            "Обновить sing-box"
            "Включить / Выключить BBR (Статус: $bbr_status)"
            "Назад"
        )
        select_menu "Настройки" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            change_domain_email_menu
        elif [ "$choice" -eq 1 ]; then
            change_site_template_menu
        elif [ "$choice" -eq 2 ]; then
            change_vless_paths_menu
        elif [ "$choice" -eq 3 ]; then
            update_singbox_menu
        elif [ "$choice" -eq 4 ]; then
            clear_screen
            print_header "Настройки → BBR Оптимизация"
            if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q "bbr"; then
                echo -e "  [*] Отключение BBR оптимизации..."
                if sysctl -w net.ipv4.tcp_congestion_control=cubic >/dev/null 2>&1; then
                    rm -f /etc/sysctl.d/99-transferbox-bbr.conf
                    sysctl --system >/dev/null 2>&1
                    echo -e "\n  ${GREEN}✓ BBR оптимизация успешно отключена (переключено на cubic).${RESET}"
                else
                    echo -e "\n  ${RED}✗ Ошибка при отключении BBR.${RESET}"
                fi
            else
                echo -e "  [*] Включение BBR оптимизации..."
                if modprobe tcp_bbr 2>/dev/null; then
                    sysctl -w net.core.default_qdisc=fq >/dev/null 2>&1
                    sysctl -w net.ipv4.tcp_congestion_control=bbr >/dev/null 2>&1
                    cat > /etc/sysctl.d/99-transferbox-bbr.conf <<EOF
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
EOF
                    sysctl --system >/dev/null 2>&1
                    echo -e "\n  ${GREEN}✓ BBR оптимизация успешно включена!${RESET}"
                else
                    echo -e "\n  ${RED}✗ Ошибка: Ядро вашей системы не поддерживает BBR.${RESET}"
                fi
            fi
            pause
        elif [ "$choice" -eq 5 ] || [ "$choice" -eq -1 ]; then
            return
        fi
    done
}

