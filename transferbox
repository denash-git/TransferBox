        tx2=$(echo "$net2" | awk '{print $2}')
        
        # –†–∞—Б—З–µ—В CPU
        local diff_idle=$(( idle2 - idle1 ))
        local diff_total=$(( total2 - total1 ))
        local cpu_pct=0
        if [ $diff_total -gt 0 ]; then
            cpu_pct=$(( (diff_total - diff_idle) * 100 / diff_total ))
        fi
        
        # –†–∞—Б—З–µ—В —Б–Ї–Њ—А–Њ—Б—В–Є —Б–µ—В–Є
        local rx_speed=$(( (rx2 - rx1) / 1024 ))
        local tx_speed=$(( (tx2 - tx1) / 1024 ))
        
        # –†–∞—Б—З–µ—В RAM
        local ram_total
        ram_total=$(free -m | awk '/Mem:/ {print $2}')
        local ram_used
        ram_used=$(free -m | awk '/Mem:/ {print $3}')
        local ram_pct=$(( ram_used * 100 / ram_total ))
        
        # –†–∞—Б—З–µ—В –Ф–Є—Б–Ї–∞
        local disk_total
        disk_total=$(df -h / | awk 'NR==2 {print $2}')
        local disk_used
        disk_used=$(df -h / | awk 'NR==2 {print $3}')
        local disk_pct
        disk_pct=$(df -h / | awk 'NR==2 {print $5}')
        
        # –§–Њ—А–Љ–∞—В–Є—А–Њ–≤–∞–љ–Є–µ —Б–Ї–Њ—А–Њ—Б—В–Є —Б–µ—В–Є
        local rx_str="${rx_speed} KB/s"
        if [ $rx_speed -gt 1024 ]; then
            rx_str=$(echo "scale=1; $rx_speed / 1024" | bc 2>/dev/null || echo "$(( rx_speed / 1024 ))")
            rx_str="${rx_str} MB/s"
        fi
        local tx_str="${tx_speed} KB/s"
        if [ $tx_speed -gt 1024 ]; then
            tx_str=$(echo "scale=1; $tx_speed / 1024" | bc 2>/dev/null || echo "$(( tx_speed / 1024 ))")
            tx_str="${tx_str} MB/s"
        fi
        
        # –Ю—В—А–Є—Б–Њ–≤–Ї–∞ TUI
        printf "\033[H"
        print_header "–Ь–Њ–љ–Є—В–Њ—А–Є–љ–≥ —А–µ—Б—Г—А—Б–Њ–≤" "false"
        
        center_print "–Ч–∞–≥—А—Г–Ј–Ї–∞ –њ—А–Њ—Ж–µ—Б—Б–Њ—А–∞ (CPU):"
        center_print "${BOLD}${cpu_pct}%${RESET}"
        echo ""
        center_print "–Ш—Б–њ–Њ–ї—М–Ј–Њ–≤–∞–љ–Є–µ –њ–∞–Љ—П—В–Є (RAM):"
        center_print "${BOLD}${ram_used} –Ь–± / ${ram_total} –Ь–± (${ram_pct}%)${RESET}"
        echo ""
        center_print "–Ч–∞–љ—П—В–Њ—Б—В—М –і–Є—Б–Ї–∞ (Disk):"
        center_print "${BOLD}${disk_used} / ${disk_total} (${disk_pct})${RESET}"
        echo ""
        center_print "–°–Ї–Њ—А–Њ—Б—В—М —Б–µ—В–Є (Interface: $iface):"
        center_print "–°–Ї–∞—З–Є–≤–∞–љ–Є–µ (RX): ${BOLD}${rx_str}${RESET}  |  –Ю—В–і–∞—З–∞ (TX): ${BOLD}${tx_str}${RESET}"
        
        echo ""
        draw_line "вФА" "$BLUE"
        center_print "${DIM}[–Э–∞–ґ–Љ–Є—В–µ Q –Є–ї–Є Enter –і–ї—П –≤–Њ–Ј–≤—А–∞—В–∞ –≤ –Љ–µ–љ—О]${RESET}"
        printf "\033[J"
    done
}

