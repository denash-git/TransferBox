}

list_users_menu() {
    while true; do
        if [ ! -f "/opt/transferbox/users.json" ] || [ "$(jq '. | length' /opt/transferbox/users.json 2>/dev/null)" -eq 0 ]; then
            clear_screen
            print_header "–°–њ–Є—Б–Њ–Ї –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–µ–є"
            echo -e "  –Я–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–µ–є –њ–Њ–Ї–∞ –љ–µ—В."
            pause
            return 0
        fi
        
        # –°—З–Є—В—Л–≤–∞–љ–Є–µ —Г–љ–Є–Ї–∞–ї—М–љ—Л—Е –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–µ–є –Є —Б–њ–Є—Б–Ї–∞ –Є—Е –њ—А–Њ—В–Њ–Ї–Њ–ї–Њ–≤
        local users_raw=()
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            users_raw+=("$line")
        done < <(jq -r 'group_by(.nickname)[] | "\((.[0].nickname))|\(map(if .protocol == "naive" then "Naive" else if .protocol == "mieru" then "Mieru" else "VLESS " + (if .credentials.type == "ws" then "WS" else if .credentials.type == "grpc" then "gRPC" else if .credentials.type == "xhttp" then "XHTTP" else .credentials.type end end end) end end) | join(", "))"' /opt/transferbox/users.json 2>/dev/null)
        
        local options=()
        local nicknames=()
        local max_nick_len=0
        
        for u in "${users_raw[@]}"; do
            IFS='|' read -r nick protos <<< "$u"
            nicknames+=("$nick")
            if [ ${#nick} -gt $max_nick_len ]; then
                max_nick_len=${#nick}
            fi
        done
        
        local col_width=$(( max_nick_len + 4 ))
        for u in "${users_raw[@]}"; do
            IFS='|' read -r nick protos <<< "$u"
            local pad_spaces=""
            local pad_len=$(( col_width - ${#nick} ))
            if [ $pad_len -gt 0 ]; then
                pad_spaces=$(printf "%${pad_len}s" "")
            fi
            options+=("$nick$pad_spaces(–Я—А–Њ—В–Њ–Ї–Њ–ї—Л: $protos)")
        done
        options+=("–Э–∞–Ј–∞–і")
        
        select_menu "–°–њ–Є—Б–Њ–Ї –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–µ–є" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq -1 ] || [ "$choice" -eq $(( ${#options[@]} - 1 )) ]; then
            return 0
        else
            local selected_nick="${nicknames[$choice]}"
            user_management_menu "$selected_nick"
        fi
    done
}

user_management_menu() {
    local nick="$1"
    while true; do
        # –Я—А–Њ–≤–µ—А—П–µ–Љ, —Б—Г—Й–µ—Б—В–≤—Г–µ—В –ї–Є –µ—Й–µ –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—М
        if ! jq -e ".[] | select(.nickname == \"$nick\")" /opt/transferbox/users.json >/dev/null 2>&1; then
            return 0
        fi
        
        # –Ч–∞–≥—А—Г–ґ–∞–µ–Љ –њ—А–Њ—В–Њ–Ї–Њ–ї—Л —Н—В–Њ–≥–Њ –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—П
        local protocols_raw=()
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            protocols_raw+=("$line")
        done < <(jq -r ".[] | select(.nickname == \"$nick\") | \"\(.protocol)|\(.credentials.type // \"\")|\(.enabled)\"" /opt/transferbox/users.json 2>/dev/null)
        
        local options=()
        local proto_types=()
        local proto_labels=()
        
        for p in "${protocols_raw[@]}"; do
            IFS='|' read -r proto utype enabled <<< "$p"
            local label=""
            if [ "$proto" == "naive" ]; then
                label="NaiveProxy"
            elif [ "$proto" == "mieru" ]; then
                label="Mieru"
            else
                label="VLESS over ${utype^^}"
            fi
            proto_labels+=("$label")
            proto_types+=("$proto|$utype|$enabled")
            
            local status_str="${RED}–Њ—В–Ї–ї—О—З–µ–љ${RESET}"
            [ "$enabled" == "true" ] && status_str="${GREEN}–∞–Ї—В–Є–≤–µ–љ${RESET}"
            options+=("вАҐ $label [$status_str]")
        done
        
        local num_protocols=${#options[@]}
        
        options+=("[+] –Ф–Њ–±–∞–≤–Є—В—М –њ—А–Њ—В–Њ–Ї–Њ–ї")
        options+=("[i] –°—Б—Л–ї–Ї–∞ –њ–Њ–і–њ–Є—Б–Ї–Є & QR")
        options+=("[x] –£–і–∞–ї–Є—В—М –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—П –њ–Њ–ї–љ–Њ—Б—В—М—О")
        options+=("–Э–∞–Ј–∞–і")
        
        select_menu "–£–њ—А–∞–≤–ї–µ–љ–Є–µ: $nick" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq -1 ] || [ "$choice" -eq $(( ${#options[@]} - 1 )) ]; then
            return 0
        elif [ "$choice" -lt "$num_protocols" ]; then
            local selected_proto="${proto_types[$choice]}"
            local selected_label="${proto_labels[$choice]}"
            IFS='|' read -r proto utype enabled <<< "$selected_proto"
            protocol_management_menu "$nick" "$proto" "$utype" "$enabled" "$selected_label"
        elif [ "$choice" -eq "$num_protocols" ]; then
            add_protocol_to_user "$nick"
        elif [ "$choice" -eq $(( num_protocols + 1 )) ]; then
            show_subscription_qr "$nick"
        elif [ "$choice" -eq $(( num_protocols + 2 )) ]; then
            local confirm
            read_prompt "–Т—Л –і–µ–є—Б—В–≤–Є—В–µ–ї—М–љ–Њ —Е–Њ—В–Є—В–µ –њ–Њ–ї–љ–Њ—Б—В—М—О —Г–і–∞–ї–Є—В—М –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—П $nick –Є –≤—Б–µ –µ–≥–Њ –њ—А–Њ—В–Њ–Ї–Њ–ї—Л? [y/N]: " confirm
            if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                echo -e "\n  [*] –£–і–∞–ї–µ–љ–Є–µ –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—П..."
                python3 -c "
from core.user_manager import delete_user
success, msg = delete_user('$nick')
print(msg)
"
                python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
                pause
                return 0
            fi
        fi
    done
}

