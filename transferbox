add_protocol_to_user() {
    local nick="$1"
    
    local has_ws=false
    local has_grpc=false
    local has_xhttp=false
    local has_naive=false
    local has_mieru=false
    
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"vless\" and .credentials.type == \"ws\")" /opt/transferbox/users.json >/dev/null 2>&1; then
        has_ws=true
    fi
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"vless\" and .credentials.type == \"grpc\")" /opt/transferbox/users.json >/dev/null 2>&1; then
        has_grpc=true
    fi
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"vless\" and .credentials.type == \"xhttp\")" /opt/transferbox/users.json >/dev/null 2>&1; then
        has_xhttp=true
    fi
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"naive\")" /opt/transferbox/users.json >/dev/null 2>&1; then
        has_naive=true
    fi
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"mieru\")" /opt/transferbox/users.json >/dev/null 2>&1; then
        has_mieru=true
    fi

    local options=()
    [ "$has_ws" == "false" ] && options+=("VLESS over WebSocket")
    [ "$has_grpc" == "false" ] && options+=("VLESS over gRPC")
    [ "$has_xhttp" == "false" ] && options+=("VLESS over XHTTP")
    [ "$has_naive" == "false" ] && options+=("NaiveProxy")
    if is_mieru_enabled && [ "$has_mieru" == "false" ]; then
        options+=("Mieru")
    fi
    
    if [ ${#options[@]} -eq 0 ]; then
