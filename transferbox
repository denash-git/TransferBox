update_singbox_menu() {
    clear_screen
    print_header "Модули → sing-box → Обновление"
    echo -e "  Получение информации о версиях..."
    
    local current
    current=$(sing-box version 2>/dev/null | head -n 1 | awk '{print $3}' || echo "не установлен")
    
    local latest
    latest=$(wget -qO- "https://api.github.com/repos/SagerNet/sing-box/releases/latest" | jq -r .tag_name 2>/dev/null || echo "")
    latest="${latest#v}"
    
    if [ -z "$latest" ]; then
        echo -e "  ${RED}✗ Ошибка: Не удалось получить последнюю версию с GitHub.${RESET}"
        pause
        return 0
    fi
    
    echo -e "\n  Текущая установленная версия: ${BOLD}$current${RESET}"
    echo -e "  Последняя официальная версия: ${BOLD}$latest${RESET}\n"
    
    local confirm
    if [ "$current" == "$latest" ]; then
        echo -e "  ${GREEN}✓ У вас уже установлена последняя официальная версия.${RESET}"
        read_prompt "Хотите переустановить/принудительно обновить версию $latest? [y/N]: " confirm
    else
        echo -e "  ${YELLOW}⚠ Доступно обновление до версии $latest!${RESET}"
        read_prompt "Продолжить обновление? [y/N]: " confirm
    fi
    
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
        echo -e "\n  [*] Запуск процесса обновления до версии $latest..."
        local arch
        arch=$(dpkg --print-architecture 2>/dev/null || uname -m)
        local go_arch="amd64"
        case "$arch" in
            amd64|x86_64) go_arch="amd64";;
            arm64|aarch64) go_arch="arm64";;
        esac
        
        local deb_url="https://github.com/SagerNet/sing-box/releases/download/v${latest}/sing-box_${latest}_linux_${go_arch}.deb"
        local deb_file="/tmp/sing-box_${latest}.deb"
        
        echo -e "  * Скачивание $deb_url..."
        wget -qO "$deb_file" "$deb_url"
        
        echo -e "  * Установка deb-пакета..."
        if dpkg -i "$deb_file" >/dev/null 2>&1; then
            echo -e "  ${GREEN}✓ sing-box успешно установлен/обновлен.${RESET}"
            rm -f "$deb_file"
            
            echo -e "  * Проверка совместимости конфигурации..."
            if ! sing-box check -c /etc/sing-box/config.json; then
                echo -e "  ${RED}✗ ВНИМАНИЕ: Новая версия не совместима с вашим конфигом!${RESET}"
                echo -e "  Служба не будет перезапущена, чтобы сохранить работоспособность."
            else
                echo -e "  * Перезапуск службы sing-box..."
                systemctl daemon-reload
                systemctl restart sing-box
                echo -e "  ${GREEN}✓ Служба sing-box успешно обновлена и перезапущена.${RESET}"
            fi
        else
            echo -e "  ${RED}✗ Ошибка установки deb-пакета через dpkg.${RESET}"
        fi
    else
        echo -e "  Обновление отменено."
    fi
    pause
}

