#!/usr/bin/env bash
# =============================================================================
# TransferBox — Панель Управления (Pure Bash TUI с навигацией стрелками)
# =============================================================================
set -euo pipefail

# ANSI Colors
BLUE='\033[1;34m'
GREEN='\033[1;32m'
RED='\033[1;31m'
YELLOW='\033[1;33m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

# Проверка запуска от root
if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo -e "${RED}Ошибка: Для запуска утилиты требуются права root. Используйте: sudo menu${RESET}" >&2
    exit 1
fi

PROJECT_ROOT="/opt/transferbox"
export PYTHONPATH="${PROJECT_ROOT}"

# ─── ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ─────────────────────────────────────────────────

clear_screen() {
    printf "\033[2J\033[H"
}

pause() {
    echo ""
    center_print "${DIM}Нажмите любую клавишу для продолжения...${RESET}"
    read -rsn1
}

read_prompt() {
    local prompt_text="$1"
    local var_name="$2"
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    local indent=$(( (term_width - 50) / 2 ))
    [ $indent -lt 2 ] && indent=2
    printf "%${indent}s%s" "" "$prompt_text"
    read -r "$var_name"
}

center_print() {
    local text="$1"
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    
    local clean_text
    clean_text=$(printf "%b" "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local text_len=${#clean_text}
    
    local padding=$(( (term_width - text_len) / 2 ))
    [ $padding -lt 0 ] && padding=0
    
    printf "%${padding}s%b\n" "" "$text"
}

draw_line() {
    local char="$1"
    local color="$2"
    local line
    line=$(printf "${char}%.0s" {1..60})
    center_print "${color}${line}${RESET}"
}

get_service_status() {
    local service_name="$1"
    if systemctl is-active "$service_name" >/dev/null 2>&1; then
        echo -e "${GREEN}● работает${RESET}"
    else
        local status
        status=$(systemctl is-active "$service_name" 2>/dev/null || echo "не установлен")
        echo -e "${RED}● не запущен ($status)${RESET}"
    fi
}

print_header() {
    local title="$1"
    local show_status="${2:-false}"
    local domain="не задан"
    if [ -f "/opt/transferbox/instance.env" ]; then
        domain=$(grep -E "^DOMAIN=" /opt/transferbox/instance.env | cut -d'=' -f2-)
    fi
    [ -z "$domain" ] && domain="не задан"
    
    local line_double
    line_double=$(printf "═%.0s" {1..60})
    local line_single
    line_single=$(printf "─%.0s" {1..60})
    
    center_print "${BLUE}${line_double}${RESET}"
    center_print "${YELLOW}${title}${RESET}"
    center_print "${BLUE}${line_single}${RESET}"
    if [ "$show_status" == "true" ]; then
        center_print "Домен: ${BOLD}${domain}${RESET}"
        center_print "Caddy: $(get_service_status caddy)"
        center_print "sing-box: $(get_service_status sing-box)"
        center_print "${BLUE}${line_double}${RESET}"
    fi
    echo ""
}

# Функция навигации стрелками
# Устанавливает переменную SELECTED_INDEX
select_menu() {
    local title="$1"
    shift
    local options=("$@")
    local num_options=${#options[@]}
    local active_idx=0
    
    # Скрыть курсор
    tput civis
    
    # Очистить экран один раз при входе в меню
    clear_screen
    
    while true; do
        # Переместить курсор в верхний левый угол
        printf "\033[H"
        
        # Определим, показывать ли статус на основе заголовка
        local show_status="false"
        if [ "$title" == "TransferBox — Панель Управления" ]; then
            show_status="true"
        fi
        
        print_header "$title" "$show_status"
        
        # Определим максимальную визуальную длину вариантов для центрирования блока
        local max_len=0
        for opt in "${options[@]}"; do
            local clean_opt
            clean_opt=$(printf "%b" "$opt" | sed 's/\x1b\[[0-9;]*m//g')
            if [ ${#clean_opt} -gt $max_len ]; then
                max_len=${#clean_opt}
            fi
        done
        
        local term_width
        term_width=$(tput cols 2>/dev/null || echo 80)
        local indent=$(( (term_width - max_len) / 2 ))
        [ $indent -lt 0 ] && indent=0
        
        for i in "${!options[@]}"; do
            if [ "$i" -eq "$active_idx" ]; then
                # Инверсия строки при выборе (код 7) с очисткой остатка строки \033[K
                printf "%${indent}s\033[7m %b \033[0m\033[K\n" "" "${options[$i]}"
            else
                printf "%${indent}s  %b \033[K\n" "" "${options[$i]}"
            fi
        done
        echo ""
        center_print "${DIM}[Используйте стрелки ↑/↓, Enter для выбора, Q/0 для выхода/назад]${RESET}"
        printf "\033[J" # Очистить всё ниже меню
        
        # Считывание нажатия клавиши
        local key
        IFS= read -rsn1 key
        if [[ "$key" == $'\x1b' ]]; then
            local next_keys
            IFS= read -rsn2 -t 0.05 next_keys
            if [[ "$next_keys" == "[A" ]]; then # Вверх
                active_idx=$(( (active_idx - 1 + num_options) % num_options ))
            elif [[ "$next_keys" == "[B" ]]; then # Вниз
                active_idx=$(( (active_idx + 1) % num_options ))
            fi
        elif [[ "$key" == "" ]]; then # Enter
            SELECTED_INDEX=$active_idx
            tput cnorm # Показать курсор
            return 0
        elif [[ "$key" == "q" || "$key" == "Q" || "$key" == "0" ]]; then
            SELECTED_INDEX=-1
            tput cnorm # Показать курсор
            return 1
        fi
    done
}

# ─── ГЛАВНОЕ МЕНЮ ────────────────────────────────────────────────────────────

main_menu() {
    while true; do
        local options=(
            "Пользователи"
            "Настройки"
            "Бэкап и Восстановление"
            "Перезапустить службы"
            "Показать логи"
            "Мониторинг ресурсов"
            "Выход"
        )
        select_menu "TransferBox — Панель Управления" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            users_menu
        elif [ "$choice" -eq 1 ]; then
            settings_menu
        elif [ "$choice" -eq 2 ]; then
            backup_restore_menu
        elif [ "$choice" -eq 3 ]; then
            apply_settings_menu
        elif [ "$choice" -eq 4 ]; then
            logs_menu
        elif [ "$choice" -eq 5 ]; then
            system_monitor_menu
        elif [ "$choice" -eq 6 ] || [ "$choice" -eq -1 ]; then
            clear_screen
            exit 0
        fi
    done
}

# ─── МЕНЮ ПОЛЬЗОВАТЕЛЕЙ ──────────────────────────────────────────────────────

users_menu() {
    while true; do
        local options=(
            "Список пользователей"
            "Добавить нового пользователя"
            "Назад"
        )
        select_menu "Пользователи" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            list_users_menu
        elif [ "$choice" -eq 1 ]; then
            create_user_menu
        elif [ "$choice" -eq 2 ] || [ "$choice" -eq -1 ]; then
            return
        fi
    done
}

list_users_menu() {
    while true; do
        if [ ! -f "/opt/transferbox/users.json" ] || [ "$(jq '. | length' /opt/transferbox/users.json 2>/dev/null)" -eq 0 ]; then
            clear_screen
            print_header "Список пользователей"
            echo -e "  Пользователей пока нет."
            pause
            return
        fi
        
        # Считывание пользователей
        local users_raw=()
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            users_raw+=("$line")
        done < <(jq -r '.[] | "\(.nickname)|\(.protocol)|\(.credentials.type // "")|\(.enabled)"' /opt/transferbox/users.json 2>/dev/null)
        
        local options=()
        for u in "${users_raw[@]}"; do
            IFS='|' read -r nick proto utype enabled <<< "$u"
            local label=""
            if [ "$proto" == "naive" ]; then
                label="NaiveProxy"
            else
                label="VLESS over ${utype^^}"
            fi
            
            local status_str=""
            if [ "$enabled" == "true" ]; then
                status_str="${GREEN}активен${RESET}"
            else
                status_str="${RED}отключен${RESET}"
            fi
            options+=("$nick ($label) [$status_str]")
        done
        options+=("Назад")
        
        select_menu "Список пользователей" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq -1 ] || [ "$choice" -eq $(( ${#options[@]} - 1 )) ]; then
            return
        else
            local user_data="${users_raw[$choice]}"
            user_submenu "$user_data"
        fi
    done
}

user_submenu() {
    local user_data="$1"
    IFS='|' read -r nick proto utype enabled <<< "$user_data"
    
    while true; do
        local status_label="${GREEN}активен${RESET}"
        if [ "$enabled" != "true" ]; then
            status_label="${RED}отключен${RESET}"
        fi
        
        local options=(
            "Включить / Выключить (Статус: $status_label)"
            "Показать ссылку подключения и QR-код"
            "Удалить пользователя"
            "Назад"
        )
        
        select_menu "Управление: $nick" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            local new_status="True"
            if [ "$enabled" == "true" ]; then
                new_status="False"
            fi
            echo -e "\n  [*] Изменение статуса пользователя..."
            python3 -c "
from core.user_manager import toggle_user
success, msg = toggle_user('$nick', $new_status, '$proto', '$utype')
print(msg)
"
            python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
            if [ "$new_status" == "True" ]; then enabled="true"; else enabled="false"; fi
            pause
        elif [ "$choice" -eq 1 ]; then
            # Находим все активные записи пользователя
            local user_records=()
            while IFS= read -r line; do
                [ -z "$line" ] && continue
                user_records+=("$line")
            done < <(jq -r ".[] | select(.nickname == \"$nick\" and .enabled == true) | \"\(.protocol)|\(.credentials.type // \"\")|\(.sub_token // \"\")\"" /opt/transferbox/users.json 2>/dev/null)
            
            if [ ${#user_records[@]} -eq 0 ]; then
                echo -e "\n  ${RED}✗ Нет активных протоколов для этого пользователя.${RESET}"
                pause
                continue
            fi
            
            local qr_options=()
            local qr_links=()
            local qr_titles=()
            
            for ur in "${user_records[@]}"; do
                IFS='|' read -r proto_item utype_item token <<< "$ur"
                local link
                link=$(python3 -c "
from core.config_manager import load_users, build_client_link
users = load_users()
user = next((u for u in users if u['nickname'] == '$nick' and u['protocol'] == '$proto_item' and u.get('credentials', {}).get('type', '') == '$utype_item'), None)
if user:
    print(build_client_link(user))
")
                if [ ! -z "$link" ]; then
                    local label=""
                    if [ "$proto_item" == "naive" ]; then
                        label="NaiveProxy Link & QR"
                    else
                        label="VLESS over ${utype_item^^} Link & QR"
                    fi
                    qr_options+=("$label")
                    qr_links+=("$link")
                    qr_titles+=("Подключение: $nick ($proto_item ${utype_item^^})")
                fi
            done
            
            local sub_token=""
            for ur in "${user_records[@]}"; do
                IFS='|' read -r proto_item utype_item token <<< "$ur"
                if [ ! -z "$token" ]; then
                    sub_token="$token"
                    break
                fi
            done
            
            if [ ! -z "$sub_token" ]; then
                local domain
                domain=$(grep -E "^DOMAIN=" /opt/transferbox/instance.env | cut -d'=' -f2-)
                [ -z "$domain" ] && domain="yourdomain.com"
                local sub_link="https://${domain}/sub/${sub_token}"
                
                qr_options+=("Ссылка Подписки & QR (Все протоколы)")
                qr_links+=("$sub_link")
                qr_titles+=("Ссылка подписки: $nick")
            fi
            qr_options+=("Назад")
            
            while true; do
                select_menu "QR-коды и ссылки: $nick" "${qr_options[@]}"
                local qr_choice=$SELECTED_INDEX
                
                if [ "$qr_choice" -eq -1 ] || [ "$qr_choice" -eq $(( ${#qr_options[@]} - 1 )) ]; then
                    break
                fi
                
                clear_screen
                print_header "${qr_titles[$qr_choice]}" "false"
                echo -e "  Ссылка:"
                echo -e "  \033[1;36m${qr_links[$qr_choice]}\033[0m"
                echo -e "\n  QR-код:"
                qrencode -t ANSIUTF8 "${qr_links[$qr_choice]}" 2>/dev/null || echo -e "  [qrencode не установлен на сервере]"
                pause
            done
        elif [ "$choice" -eq 2 ]; then
            local confirm
            read_prompt "Вы действительно хотите удалить протокол $proto ${utype^^} для $nick? [y/N]: " confirm
            if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                python3 -c "
from core.user_manager import delete_user
success, msg = delete_user('$nick', '$proto', '$utype')
print(msg)
"
                python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
                pause
                return
            fi
        elif [ "$choice" -eq 3 ] || [ "$choice" -eq -1 ]; then
            return
        fi
    done
}

create_user_menu() {
    clear_screen
    print_header "Новый пользователь"
    
    local nick
    read_prompt "Введите никнейм пользователя: " nick
    nick="${nick// /}"
    if [ -z "$nick" ]; then
        echo -e "\n  ${RED}✗ Никнейм не может быть пустым.${RESET}"
        pause
        return
    fi
    
    # Проверить, существует ли никнейм уже в базе
    if [ -f "/opt/transferbox/users.json" ] && jq -e ".[] | select(.nickname == \"$nick\")" /opt/transferbox/users.json >/dev/null 2>&1; then
        echo -e "\n  ${YELLOW}⚠ Пользователь с никнеймом '$nick' уже существует.${RESET}"
        local confirm
        read_prompt "Хотите добавить ему дополнительный протокол? [y/N]: " confirm
        if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
            echo -e "  Создание пользователя отменено."
            pause
            return
        fi
    fi
    
    local options=(
        "VLESS over WebSocket"
        "VLESS over gRPC"
        "VLESS over XHTTP"
        "NaiveProxy"
        "Отмена"
    )
    select_menu "Протокол для $nick" "${options[@]}"
    local choice=$SELECTED_INDEX
    
    local protocol=""
    local user_type=""
    if [ "$choice" -eq 0 ]; then
        protocol="vless"
        user_type="ws"
    elif [ "$choice" -eq 1 ]; then
        protocol="vless"
        user_type="grpc"
    elif [ "$choice" -eq 2 ]; then
        protocol="vless"
        user_type="xhttp"
    elif [ "$choice" -eq 3 ]; then
        protocol="naive"
    else
        return
    fi
    
    echo -e "\n  [*] Добавление пользователя..."
    local create_res
    create_res=$(python3 -c "
from core.user_manager import add_user
success, user = add_user('$nick', '$protocol', '$user_type')
if success:
    print('SUCCESS')
else:
    print(user)
")
    
    if [ "$create_res" == "SUCCESS" ]; then
        python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
        clear_screen
        local link
        link=$(python3 -c "
from core.config_manager import load_users, build_client_link
users = load_users()
user = next((u for u in users if u['nickname'] == '$nick' and u['protocol'] == '$protocol' and u.get('credentials', {}).get('type', '') == '$user_type'), None)
if user:
    print(build_client_link(user))
")
        print_header "Пользователь создан: $nick"
        echo -e "  Пользователь успешно создан и зарегистрирован!\n"
        echo -e "  Ссылка для подключения:"
        echo -e "  \033[1;36m$link\033[0m"
        echo -e "\n  QR-код:"
        qrencode -t ANSIUTF8 "$link" 2>/dev/null || echo -e "  [qrencode не установлен на сервере]"
    else
        echo -e "\n  ${RED}✗ Ошибка создания пользователя: $create_res${RESET}"
    fi
    pause
}

# ─── НАСТРОЙКИ ───────────────────────────────────────────────────────────────

settings_menu() {
    while true; do
        if [ -f "/opt/transferbox/instance.env" ]; then
            source /opt/transferbox/instance.env
        fi
        local domain="${DOMAIN:-не задан}"
        local email="${ADMIN_EMAIL:-не задан (анонимный SSL)}"
        [ -z "$email" ] && email="не задан (анонимный SSL)"
        local template="${FAKE_SITE_TEMPLATE:-aether}"
        local vless_ws="${VLESS_WS_PATH:-/}"
        local vless_grpc="${VLESS_GRPC_SERVICE:-(пусто)}"
        [ -z "$vless_grpc" ] && vless_grpc="(пусто)"
        local vless_xhttp="${VLESS_XHTTP_PATH:-/xhttp}"
        
        local bbr_status="${RED}отключен${RESET}"
        if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q "bbr"; then
            bbr_status="${GREEN}активен${RESET}"
        fi
        
        clear_screen
        print_header "Настройки"
        echo -e "  Текущая конфигурация:"
        echo -e "  • Домен:             $domain"
        echo -e "  • Email Let's Encrypt: $email"
        echo -e "  • Шаблон сайта:      $template"
        echo -e "  • Путь VLESS WS:     $vless_ws"
        echo -e "  • Сервис VLESS gRPC:  $vless_grpc"
        echo -e "  • Путь VLESS XHTTP:  $vless_xhttp"
        echo -e "  • TCP BBR:           $bbr_status"
        draw_line "─" "$BLUE"
        
        local options=(
            "Изменить Домен и Email"
            "Выбрать шаблон маскировочного сайта"
            "Настроить пути VLESS"
            "Обновить sing-box"
            "Включить / Выключить BBR (Статус: $bbr_status)"
            "Назад"
        )
        select_menu "Настройки" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            change_domain_email_menu
        elif [ "$choice" -eq 1 ]; then
            change_site_template_menu
        elif [ "$choice" -eq 2 ]; then
            change_vless_paths_menu
        elif [ "$choice" -eq 3 ]; then
            update_singbox_menu
        elif [ "$choice" -eq 4 ]; then
            clear_screen
            print_header "Настройки → BBR Оптимизация"
            if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q "bbr"; then
                echo -e "  [*] Отключение BBR оптимизации..."
                if sysctl -w net.ipv4.tcp_congestion_control=cubic >/dev/null 2>&1; then
                    rm -f /etc/sysctl.d/99-transferbox-bbr.conf
                    sysctl --system >/dev/null 2>&1
                    echo -e "\n  ${GREEN}✓ BBR оптимизация успешно отключена (переключено на cubic).${RESET}"
                else
                    echo -e "\n  ${RED}✗ Ошибка при отключении BBR.${RESET}"
                fi
            else
                echo -e "  [*] Включение BBR оптимизации..."
                if modprobe tcp_bbr 2>/dev/null; then
                    sysctl -w net.core.default_qdisc=fq >/dev/null 2>&1
                    sysctl -w net.ipv4.tcp_congestion_control=bbr >/dev/null 2>&1
                    cat > /etc/sysctl.d/99-transferbox-bbr.conf <<EOF
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
EOF
                    sysctl --system >/dev/null 2>&1
                    echo -e "\n  ${GREEN}✓ BBR оптимизация успешно включена!${RESET}"
                else
                    echo -e "\n  ${RED}✗ Ошибка: Ядро вашей системы не поддерживает BBR.${RESET}"
                fi
            fi
            pause
        elif [ "$choice" -eq 5 ] || [ "$choice" -eq -1 ]; then
            return
        fi
    done
}

change_domain_email_menu() {
    clear_screen
    print_header "Настройки → Домен и Email"
    source /opt/transferbox/instance.env
    
    echo -e "  Текущий домен: ${DOMAIN:-не задан}"
    echo -e "  Текущий Email: ${ADMIN_EMAIL:-не задан (анонимный SSL)}"
    draw_line "─" "$BLUE"
    
    local new_domain
    read_prompt "Введите новый домен (или Enter для отмены): " new_domain
    new_domain="${new_domain// /}"
    
    local changed=false
    if [ ! -z "$new_domain" ]; then
        python3 -c "from core.config_manager import load_env, save_env; env = load_env(); env['DOMAIN'] = '$new_domain'; save_env(env)"
        changed=true
        echo -e "  ${GREEN}✓ Домен изменен на $new_domain${RESET}"
    fi
    
    echo -e "\n  Для анонимного SSL (без почты) введите символ '-'"
    local new_email
    read_prompt "Введите новый Email (или Enter для отмены): " new_email
    new_email="${new_email// /}"
    
    if [ "$new_email" == "-" ]; then
        python3 -c "from core.config_manager import load_env, save_env; env = load_env(); env['ADMIN_EMAIL'] = ''; save_env(env)"
        changed=true
        echo -e "  ${GREEN}✓ Email удален (анонимный SSL активирован)${RESET}"
    elif [ ! -z "$new_email" ]; then
        python3 -c "from core.config_manager import load_env, save_env; env = load_env(); env['ADMIN_EMAIL'] = '$new_email'; save_env(env)"
        changed=true
        echo -e "  ${GREEN}✓ Email изменен на $new_email${RESET}"
    fi
    
    if [ "$changed" == "true" ]; then
        echo -e "\n  Применяем настройки..."
        python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
    fi
    pause
}

change_site_template_menu() {
    clear_screen
    print_header "Настройки → Шаблон сайта"
    source /opt/transferbox/instance.env
    echo -e "  Текущий шаблон: ${FAKE_SITE_TEMPLATE:-aether}\n"
    
    local options=(
        "Aether Resonance (Эфирный Резонанс)"
