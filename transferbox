    latest=$(wget -qO- "https://api.github.com/repos/SagerNet/sing-box/releases/latest" | jq -r .tag_name 2>/dev/null || echo "")
    latest="${latest#v}"
    
    if [ -z "$latest" ]; then
        echo -e "  ${RED}вЬЧ –Ю—И–Є–±–Ї–∞: –Э–µ —Г–і–∞–ї–Њ—Б—М –њ–Њ–ї—Г—З–Є—В—М –њ–Њ—Б–ї–µ–і–љ—О—О –≤–µ—А—Б–Є—О —Б GitHub.${RESET}"
        pause
        return 0
