# вФАвФАвФА –Ф–Ш–Р–У–Э–Ю–°–Ґ–Ш–Ъ–Р (SPEEDTEST) вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА

diagnostics_menu() {
    while true; do
        local options=(
            "–Ґ–µ—Б—В VPS вЖТ –Ш–љ—В–µ—А–љ–µ—В (speedtest-cli)"
            "–Ч–∞–Љ–µ—А —Б–Ї–Њ—А–Њ—Б—В–Є Client вЖФ VPS (–≤–µ–±-—Б—В—А–∞–љ–Є—Ж–∞)"
            "–Я–Њ–Ї–∞–Ј–∞—В—М —В–µ–Ї—Г—Й–Є–є –њ—А–µ—Д–Є–Ї—Б speedtest"
            "–Я–µ—А–µ–≥–µ–љ–µ—А–Є—А–Њ–≤–∞—В—М –њ—А–µ—Д–Є–Ї—Б speedtest"
            "–Э–∞–Ј–∞–і"
        )
        select_menu "–Ф–Є–∞–≥–љ–Њ—Б—В–Є–Ї–∞" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            run_speedtest_vps_internet
        elif [ "$choice" -eq 1 ]; then
            run_speedtest_client_vps
        elif [ "$choice" -eq 2 ]; then
            show_speedtest_prefix
        elif [ "$choice" -eq 3 ]; then
            regenerate_speedtest_prefix_menu
        elif [ "$choice" -eq 4 ] || [ "$choice" -eq -1 ]; then
            return 0
        fi
    done
}

run_speedtest_vps_internet() {
    # Check if official speedtest is installed, if not install it
    if ! dpkg -s speedtest >/dev/null 2>&1; then
        clear_screen
        print_header "–°–Ї–Њ—А–Њ—Б—В—М VPS вЖТ –Ш–љ—В–µ—А–љ–µ—В" "false"
        echo -e "  [*] –£—Б—В–∞–љ–Њ–≤–Ї–∞ –Њ—Д–Є—Ж–Є–∞–ї—М–љ–Њ–≥–Њ Ookla Speedtest..."
        sudo apt-get purge -y speedtest-cli >/dev/null 2>&1 || true
        sudo apt-get install -f -y >/dev/null 2>&1 || true
        curl -s https://packagecloud.io/install/repositories/ookla/speedtest-cli/script.deb.sh | sudo bash >/dev/null 2>&1
        sudo apt-get install -y speedtest >/dev/null 2>&1
    fi

    if ! command -v speedtest >/dev/null 2>&1; then
        echo -e "  ${RED}вЬЧ –Э–µ —Г–і–∞–ї–Њ—Б—М —Г—Б—В–∞–љ–Њ–≤–Є—В—М speedtest.${RESET}"
        pause
        return 0
    fi

    while true; do
        local options=(
            "–Ґ–µ—Б—В –љ–∞ –±–ї–Є–ґ–∞–є—И–µ–Љ —Б–µ—А–≤–µ—А–µ (–∞–≤—В–Њ–≤—Л–±–Њ—А)"
            "–Т—Л–±—А–∞—В—М —Б–µ—А–≤–µ—А –Є–Ј —Б–њ–Є—Б–Ї–∞ –±–ї–Є–ґ–∞–є—И–Є—Е"
            "–Э–∞–Ј–∞–і"
        )
        select_menu "VPS вЖТ –Ш–љ—В–µ—А–љ–µ—В" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            clear_screen
            print_header "–°–Ї–Њ—А–Њ—Б—В—М VPS вЖТ –Ш–љ—В–µ—А–љ–µ—В (–Р–≤—В–Њ–≤—Л–±–Њ—А)" "false"
            echo -e "  ${CYAN}–Ч–∞–њ—Г—Б–Ї —В–µ—Б—В–∞, –њ–Њ–і–Њ–ґ–і–Є—В–µ...${RESET}\n"
            speedtest --accept-license --accept-gdpr 2>&1 | sed 's/^/  /'
            echo
            pause
            return 0
        elif [ "$choice" -eq 1 ]; then
            clear_screen
            print_header "–Я–Њ–Є—Б–Ї –±–ї–Є–ґ–∞–є—И–Є—Е —Б–µ—А–≤–µ—А–Њ–≤" "false"
            echo -e "  [*] –Я–Њ–ї—Г—З–µ–љ–Є–µ —Б–њ–Є—Б–Ї–∞ —Б–µ—А–≤–µ—А–Њ–≤..."
            
            local servers_raw=()
            while IFS= read -r line; do
                [ -z "$line" ] && continue
                if [[ "$line" =~ ^[[:space:]]*([0-9]+)[[:space:]]+(.*)$ ]]; then
                    servers_raw+=("${BASH_REMATCH[1]}|${BASH_REMATCH[2]}")
                fi
            done < <(speedtest -L --accept-license --accept-gdpr 2>/dev/null)
            
            if [ ${#servers_raw[@]} -eq 0 ]; then
                echo -e "\n  ${RED}вЬЧ –Э–µ —Г–і–∞–ї–Њ—Б—М –њ–Њ–ї—Г—З–Є—В—М —Б–њ–Є—Б–Њ–Ї —Б–µ—А–≤–µ—А–Њ–≤.${RESET}"
                pause
                continue
            fi
            
            local select_opts=()
            local select_ids=()
            for s in "${servers_raw[@]}"; do
                IFS='|' read -r id details <<< "$s"
                details=$(echo "$details" | tr -s ' ')
                select_opts+=("[$id] $details")
                select_ids+=("$id")
            done
            select_opts+=("–Э–∞–Ј–∞–і")
            
            select_menu "–Т—Л–±–µ—А–Є—В–µ —Б–µ—А–≤–µ—А" "${select_opts[@]}"
            local sel_choice=$SELECTED_INDEX
            
            if [ "$sel_choice" -eq -1 ] || [ "$sel_choice" -eq $(( ${#select_opts[@]} - 1 )) ]; then
                continue
            fi
            
            local selected_id="${select_ids[$sel_choice]}"
            local selected_name="${select_opts[$sel_choice]}"
            
            clear_screen
            print_header "VPS вЖТ –Ш–љ—В–µ—А–љ–µ—В ($selected_name)" "false"
            echo -e "  ${CYAN}–Ч–∞–њ—Г—Б–Ї —В–µ—Б—В–∞ –љ–∞ —Б–µ—А–≤–µ—А–µ $selected_id, –њ–Њ–і–Њ–ґ–і–Є—В–µ...${RESET}\n"
            speedtest -s "$selected_id" --accept-license --accept-gdpr 2>&1 | sed 's/^/  /'
            echo
            pause
            return 0
        else
            return 0
        fi
    done
}

run_speedtest_client_vps() {
    clear_screen
    print_header "–Ч–∞–Љ–µ—А —Б–Ї–Њ—А–Њ—Б—В–Є: Client вЖФ VPS" "false"
    echo -e "  –Т—А–µ–Љ–µ–љ–љ–∞—П HTTPS-—Б—Б—Л–ї–Ї–∞ –љ–∞ 10 –Љ–Є–љ—Г—В –і–ї—П —В–µ—Б—В–Є—А–Њ–≤–∞–љ–Є—П —Б–Ї–Њ—А–Њ—Б—В–Є."
    echo -e "  –Ю—В–Ї—А–Њ–є—В–µ –µ—С –≤ –±—А–∞—Г–Ј–µ—А–µ –і–ї—П –Ј–∞–њ—Г—Б–Ї–∞ –Ј–∞–Љ–µ—А–∞ (—В—А–∞—Д–Є–Ї –Є–і–µ—В –њ–Њ –њ–Њ—А—В—Г 443).\n"
    
    if ! systemctl is-active transferbox-speedtest --quiet 2>/dev/null; then
        echo -e "  [*] –Ч–∞–њ—Г—Б–Ї —Б–ї—Г–ґ–±—Л speedtest..."
        sudo systemctl start transferbox-speedtest >/dev/null 2>&1
    fi
    
    local token expires_at expires_human url domain prefix
    token=$(openssl rand -hex 12)
    expires_at=$(( $(date +%s) + 600 ))
    expires_human=$(date -d "@${expires_at}" '+%Y-%m-%d %H:%M:%S %Z' 2>/dev/null || date -u -d "@${expires_at}" '+%Y-%m-%d %H:%M:%S UTC')
    
