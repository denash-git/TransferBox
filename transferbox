#!/usr/bin/env bash
# =============================================================================
# TransferBox — Панель Управления (Pure Bash TUI с навигацией стрелками)
# =============================================================================
set -euo pipefail

PROJECT_ROOT="/opt/transferbox"
export PYTHONPATH="${PROJECT_ROOT}"
VERSION="2.0.2"

# ANSI Colors
if [ -f "${PROJECT_ROOT}/lib/colors.sh" ]; then
    source "${PROJECT_ROOT}/lib/colors.sh"
else
    BLUE='\033[1;34m'
    GREEN='\033[1;32m'
    RED='\033[1;31m'
    YELLOW='\033[1;33m'
    CYAN='\033[1;36m'
    DIM='\033[2m'
    BOLD='\033[1m'
    RESET='\033[0m'
fi

# Проверка запуска от root
if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo -e "${RED}Ошибка: Для запуска утилиты требуются права root. Используйте: sudo menu${RESET}" >&2
    exit 1
fi

LOG_LINES_COUNT=100

# ─── ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ─────────────────────────────────────────────────

clear_screen() {
    printf "\033[2J\033[H"
}

pause() {
    echo ""
    center_print "${DIM}Нажмите любую клавишу для продолжения...${RESET}"
    read -rsn1
}

read_prompt() {
    local prompt_text="$1"
    local var_name="$2"
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    local indent=$(( (term_width - 50) / 2 ))
    [ $indent -lt 2 ] && indent=2
    printf "%${indent}s%s" "" "$prompt_text"
    read -r "$var_name"
}

center_print() {
    local text="$1"
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    
    local clean_text
    clean_text=$(printf "%b" "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local text_len=${#clean_text}
    
    local padding=$(( (term_width - text_len) / 2 ))
    [ $padding -lt 0 ] && padding=0
    
    printf "%${padding}s%b\n" "" "$text"
}

center_print_no_newline() {
    local text="$1"
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    
    local clean_text
    clean_text=$(printf "%b" "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local text_len=${#clean_text}
    
    local padding=$(( (term_width - text_len) / 2 ))
    [ $padding -lt 0 ] && padding=0
    
    printf "%${padding}s%b" "" "$text"
}

draw_line() {
    local char="$1"
    local color="$2"
    local line
    line=$(printf "${char}%.0s" {1..60})
    center_print "${color}${line}${RESET}"
}

get_service_status() {
    local service_name="$1"
    if systemctl is-active --quiet "$service_name" 2>/dev/null; then
        echo -e "${GREEN}● работает${RESET}"
    else
        local status
        status=$(systemctl is-active "$service_name" 2>/dev/null)
        [ -z "$status" ] && status="inactive"
        echo -e "${RED}● не запущен ($status)${RESET}"
    fi
}


UPDATE_BADGE=""
HEADER_DOMAIN=""
HEADER_FQDN=""
HEADER_BBR_DOT=""
HEADER_BBR_DOT_RAW=""
HEADER_STATUS_CADDY=""
HEADER_STATUS_CAD_RAW=""
HEADER_STATUS_SINGBOX=""
HEADER_STATUS_SB_RAW=""
HEADER_SHOW_MIERU=false
HEADER_STATUS_MITA=""
HEADER_STATUS_MITA_RAW=""
HEADER_SHOW_NETBIRD=false
HEADER_STATUS_NETBIRD=""
HEADER_STATUS_NB_RAW=""

load_update_badge() {
    local cache_file="${PROJECT_ROOT}/.tb_update_cache"
    if [ -f "$cache_file" ]; then
        local latest=""
        read -r latest < "$cache_file" 2>/dev/null || latest=""
        if [ -n "$latest" ] && [ "$latest" != "$VERSION" ]; then
            if [ "$(printf '%s\n' "$VERSION" "$latest" | sort -V | head -n 1)" == "$VERSION" ]; then
                UPDATE_BADGE="${GREEN}[↑ update v$latest]${RESET}"
                return
            fi
        fi
    fi
    UPDATE_BADGE=""
}

refresh_system_status() {
    local domain="не задан"
    if [ -f "${PROJECT_ROOT}/instance.env" ]; then
        domain=$(grep -E "^DOMAIN=" ${PROJECT_ROOT}/instance.env | cut -d'=' -f2- | tr -d '\r')
    fi
    [ -z "$domain" ] && domain="не задан"
    HEADER_DOMAIN="$domain"
    
    HEADER_FQDN=$(hostname -f 2>/dev/null || hostname)
    
    if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q "bbr"; then
        HEADER_BBR_DOT="${GREEN}● активен${RESET}"
        HEADER_BBR_DOT_RAW="● активен"
    else
        HEADER_BBR_DOT="${RED}● отключен${RESET}"
        HEADER_BBR_DOT_RAW="● отключен"
    fi
    
    local caddy_val
    caddy_val=$(get_service_status caddy)
    HEADER_STATUS_CADDY="$caddy_val"
    HEADER_STATUS_CAD_RAW=$(echo "$caddy_val" | sed 's/\x1b\[[0-9;]*m//g')
    
    local sb_val
    sb_val=$(get_service_status sing-box)
    HEADER_STATUS_SINGBOX="$sb_val"
    HEADER_STATUS_SB_RAW=$(echo "$sb_val" | sed 's/\x1b\[[0-9;]*m//g')
    
    HEADER_SHOW_MIERU=false
    if [ -f "/usr/bin/mita" ]; then
        HEADER_SHOW_MIERU=true
        local mita_val
        mita_val=$(get_service_status mita)
        HEADER_STATUS_MITA="$mita_val"
        HEADER_STATUS_MITA_RAW=$(echo "$mita_val" | sed 's/\x1b\[[0-9;]*m//g')
    fi
    
    HEADER_SHOW_NETBIRD=false
    if command -v netbird &>/dev/null; then
        HEADER_SHOW_NETBIRD=true
        local nb_val
        nb_val=$(get_netbird_status)
        HEADER_STATUS_NETBIRD="$nb_val"
        HEADER_STATUS_NB_RAW=$(echo "$nb_val" | sed 's/\x1b\[[0-9;]*m//g')
    fi
}

print_header() {
    local title="$1"
    
    if [[ "$title" == "TransferBox v. "* ]]; then
        load_update_badge
        if [ -n "${UPDATE_BADGE:-}" ]; then
            title="${title} ${UPDATE_BADGE}"
        fi
    fi
    
    local show_status="${2:-false}"
    
    local line_double
    line_double=$(printf "═%.0s" {1..60})
    local line_single
    line_single=$(printf "─%.0s" {1..60})
    
    center_print "${BLUE}${line_double}${RESET}"
    center_print "${YELLOW}${title}${RESET}"
    
    if [ "$show_status" == "true" ]; then
        local domain="${HEADER_DOMAIN:-не задан}"
        local vps_fqdn="${HEADER_FQDN:-}"
        local bbr_dot="${HEADER_BBR_DOT:-}"
        local bbr_dot_raw="${HEADER_BBR_DOT_RAW:-}"
        local status_cad_raw="${HEADER_STATUS_CAD_RAW:-}"
        local status_sb_raw="${HEADER_STATUS_SB_RAW:-}"
        
        local len_dom=$(( 14 + ${#domain} ))
        local len_fqdn=$(( 14 + ${#vps_fqdn} ))
        local len_cad=$(( 14 + ${#status_cad_raw} ))
        local len_sb=$(( 14 + ${#status_sb_raw} ))
        local len_bbr=$(( 14 + ${#bbr_dot_raw} ))
        
        local max_block_len=$len_dom
        [ $len_fqdn -gt $max_block_len ] && max_block_len=$len_fqdn
        [ $len_cad -gt $max_block_len ] && max_block_len=$len_cad
        [ $len_sb -gt $max_block_len ] && max_block_len=$len_sb
        [ $len_bbr -gt $max_block_len ] && max_block_len=$len_bbr
        
        local show_mieru="${HEADER_SHOW_MIERU:-false}"
        if [ "$show_mieru" == "true" ]; then
            local status_mita_raw="${HEADER_STATUS_MITA_RAW:-}"
            local len_mita=$(( 14 + ${#status_mita_raw} ))
            [ $len_mita -gt $max_block_len ] && max_block_len=$len_mita
        fi
        
        local show_netbird="${HEADER_SHOW_NETBIRD:-false}"
        if [ "$show_netbird" == "true" ]; then
            local status_nb_raw="${HEADER_STATUS_NB_RAW:-}"
            local len_nb=$(( 14 + ${#status_nb_raw} ))
            [ $len_nb -gt $max_block_len ] && max_block_len=$len_nb
        fi
        
        local term_width
        term_width=$(tput cols 2>/dev/null || echo 80)
        local indent=$(( (term_width - max_block_len) / 2 ))
        [ $indent -lt 0 ] && indent=0
        local pad_spaces
        pad_spaces=$(printf "%${indent}s" "")
        
        echo ""
        echo -e "${pad_spaces}Домен:        ${BOLD}${domain}${RESET}"
        echo -e "${pad_spaces}FQDN VPS:     ${BOLD}${vps_fqdn}${RESET}"
    fi
    
    center_print "${BLUE}${line_single}${RESET}"
    
    if [ "$show_status" == "true" ]; then
        echo -e "${pad_spaces}TCP BBR:      $bbr_dot"
        echo -e "${pad_spaces}Caddy:        ${HEADER_STATUS_CADDY:-}"
        echo -e "${pad_spaces}sing-box:     ${HEADER_STATUS_SINGBOX:-}"
        if [ "$show_mieru" == "true" ]; then
            echo -e "${pad_spaces}Mieru:        ${HEADER_STATUS_MITA:-}"
        fi
        if [ "$show_netbird" == "true" ]; then
            echo -e "${pad_spaces}NetBird:      ${HEADER_STATUS_NETBIRD:-}"
        fi
        center_print "${BLUE}${line_double}${RESET}"
    fi
    echo ""
}

# Функция навигации стрелками
# Устанавливает переменную SELECTED_INDEX
select_menu() {
    local -n _result_ref=$1
    local title="$2"
    shift 2
    local options=("$@")
    local num_options=${#options[@]}
    local active_idx=0
    
    # Скрыть курсор
    tput civis
    
    # Очистить экран один раз при входе в меню
    clear_screen
    
    while true; do
        # Переместить курсор в верхний левый угол
        printf "\033[H"
        
        # Определим, показывать ли статус на основе заголовка
        local show_status="false"
        if [ "$title" == "TransferBox v. ${VERSION}" ]; then
            show_status="true"
        fi
        
        print_header "$title" "$show_status"
        
        # Определим максимальную визуальную длину вариантов для центрирования блока
        local max_len=0
        for opt in "${options[@]}"; do
            local clean_opt
            clean_opt=$(printf "%b" "$opt" | sed 's/\x1b\[[0-9;]*m//g')
            if [ ${#clean_opt} -gt $max_len ]; then
                max_len=${#clean_opt}
            fi
        done
        
        local term_width
        term_width=$(tput cols 2>/dev/null || echo 80)
        local indent=$(( (term_width - max_len) / 2 ))
        [ $indent -lt 0 ] && indent=0
        
        for i in "${!options[@]}"; do
            local opt="${options[$i]}"
            local clean_opt
            clean_opt=$(printf "%b" "$opt" | sed 's/\x1b\[[0-9;]*m//g')
            
            # Добавим пустую строку между всеми пунктами меню для крупного/просторного вида
            if [ "$i" -ne 0 ]; then
                printf "\n"
            fi
            
            # Добавим еще одну пустую строку перед "Назад", "Отмена", "Выход" для дополнительного отделения
            if [[ "$clean_opt" =~ ^(Назад|Отмена|Выход)$ ]] && [ "$i" -ne 0 ]; then
                printf "\n"
            fi
            
            # Сделаем "Назад", "Отмена", "Выход" желтыми
            if [[ "$clean_opt" =~ ^(Назад|Отмена|Выход)$ ]]; then
                if [[ "$opt" != *$'\033'* ]]; then
                    opt="${YELLOW}${opt}${RESET}"
                fi
            fi
            
            # Сделаем все действия "Удалить" и "Пересоздать конфигурации" красными
            if [[ "$clean_opt" == *"Удалить"* || "$clean_opt" == "Пересоздать конфигурации" ]]; then
                if [[ "$opt" != *$'\033'* ]]; then
                    opt="${RED}${opt}${RESET}"
                fi
            fi
            
            # Вычисляем паддинг для центрирования или левого выравнивания
            local padding_len=$(( max_len - ${#clean_opt} ))
            local text_to_draw=""
            
            if [[ "$clean_opt" =~ ^(Назад|Отмена|Выход)$ ]]; then
                # Центрируем эти кнопки внутри общей ширины меню
                local pad_left=$(( padding_len / 2 ))
                local pad_right=$(( padding_len - pad_left ))
                local spaces_left=""
                local spaces_right=""
                [ $pad_left -gt 0 ] && spaces_left=$(printf "%${pad_left}s" "")
                [ $pad_right -gt 0 ] && spaces_right=$(printf "%${pad_right}s" "")
                
                if [ "$i" -eq "$active_idx" ]; then
                    text_to_draw="$spaces_left$clean_opt$spaces_right"
                    # Желтый фон, черный текст
                    printf "%${indent}s\033[43;30m  %b  \033[0m\033[K\n" "" "$text_to_draw"
                else
                    text_to_draw="$spaces_left$opt$spaces_right"
                    printf "%${indent}s  %b  \033[K\n" "" "$text_to_draw"
                fi
            else
                # Левое выравнивание для обычных пунктов
                local padding=""
                [ $padding_len -gt 0 ] && padding=$(printf "%${padding_len}s" "")
                
                if [ "$i" -eq "$active_idx" ]; then
                    text_to_draw="$clean_opt$padding"
                    if [[ "$clean_opt" == *"Удалить"* || "$clean_opt" == "Пересоздать конфигурации" ]]; then
                        # Красный фон, черный текст
                        printf "%${indent}s\033[41;30m  %b  \033[0m\033[K\n" "" "$text_to_draw"
                    else
                        # Стандартная инверсия (белый/серый фон, черный текст)
                        printf "%${indent}s\033[7m  %b  \033[0m\033[K\n" "" "$text_to_draw"
                    fi
                else
                    text_to_draw="$opt$padding"
                    printf "%${indent}s  %b  \033[K\n" "" "$text_to_draw"
                fi
            fi
        done
        printf "\033[J" # Очистить всё ниже меню
        
        # Отрисовка строки подсказок в самом низу экрана без прокрутки
        local term_height
        term_height=$(tput lines 2>/dev/null || echo 24)
        printf "\033[%d;1H\033[K" "$term_height"
        center_print_no_newline "${DIM}↑↓ — выбор   Enter — выбрать   q — назад   0 — Выход${RESET}"
        
        # Считывание нажатия клавиши
        local key
        IFS= read -rsn1 key
        if [[ "$key" == $'\x1b' ]]; then
            local next_keys
            IFS= read -rsn2 -t 0.05 next_keys
            if [[ "$next_keys" == "[A" ]]; then # Вверх
                active_idx=$(( (active_idx - 1 + num_options) % num_options ))
            elif [[ "$next_keys" == "[B" ]]; then # Вниз
                active_idx=$(( (active_idx + 1) % num_options ))
            fi
        elif [[ "$key" == "" ]]; then # Enter
            _result_ref=$active_idx
            tput cnorm # Показать курсор
            return 0
        elif [[ "$key" == "q" || "$key" == "Q" ]]; then
            _result_ref=-1
            tput cnorm # Показать курсор
            return 0
        elif [[ "$key" == "0" ]]; then
            clear_screen
            tput cnorm # Показать курсор
            exit 0
        fi
    done
}

# Запуск асинхронной проверки обновлений в фоне
check_updates_async() {
    local tmp_file="${PROJECT_ROOT}/.tb_update_cache"
    # Удаляем старый файл перед новой фоновой проверкой
    rm -f "$tmp_file"
    (
        # Дадим меню спокойно отрисоваться на экране
        sleep 0.5
        set +euo pipefail
        local latest
        latest=$(curl -s --connect-timeout 2 https://raw.githubusercontent.com/denash-git/TransferBox/main/transferbox | grep -E "^VERSION=" | head -n1 | cut -d'"' -f2)
        if [ -n "$latest" ]; then
            echo "$latest" > "$tmp_file"
        fi
    ) &>/dev/null &
}

# ─── ГЛАВНОЕ МЕНЮ ────────────────────────────────────────────────────────────

main_menu() {
    while true; do
        # Обновляем статусы служб при каждом возврате в главное меню
        refresh_system_status
        # Проверяем кэш обновлений при входе в главное меню (раз в 1 час)
        if [ ! -f "${PROJECT_ROOT}/.tb_update_cache" ] || \
           [ $(( $(date +%s) - $(stat -c %Y "${PROJECT_ROOT}/.tb_update_cache" 2>/dev/null || echo 0) )) -gt 3600 ]; then
            check_updates_async
        fi
        load_update_badge

        local options=(
            "Пользователи"
            "Настройки"
            "Модули"
            "Диагностика"
            "Бэкап и Восстановление"
            "Выход"
        )
        select_menu SELECTED_INDEX "TransferBox v. ${VERSION}" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            users_menu
        elif [ "$choice" -eq 1 ]; then
            settings_menu
        elif [ "$choice" -eq 2 ]; then
            modules_menu
        elif [ "$choice" -eq 3 ]; then
            diagnostics_menu
        elif [ "$choice" -eq 4 ]; then
            backup_restore_menu
        elif [ "$choice" -eq 5 ] || [ "$choice" -eq -1 ]; then
            clear_screen
            exit 0
        fi
    done
}

# ─── МОДУЛИ ──────────────────────────────────────────────────────────────────

is_mieru_enabled() {
    local val
    val=$(grep -E "^MIERU_ENABLED=" ${PROJECT_ROOT}/instance.env | cut -d'=' -f2- | tr -d '\r')
    [ "$val" == "true" ] && return 0
    return 1
}

get_netbird_status() {
    local no_dot="${1:-false}"
    local dot="● "
    [ "$no_dot" == "true" ] && dot=""

    if ! command -v netbird &>/dev/null; then
        echo -e "${RED}${dot}не установлен${RESET}"
        return 0
    fi
    
    if ! systemctl is-active --quiet netbird; then
        echo -e "${RED}${dot}остановлен (служба)${RESET}"
        return 0
    fi
    
    local status_out
    status_out=$(netbird status 2>&1 || true)
    
    if echo "$status_out" | grep -qi "NeedsLogin"; then
        echo -e "${YELLOW}${dot}требует авторизации${RESET}"
    elif echo "$status_out" | grep -qi "Connected" && ! echo "$status_out" | grep -qi "Management: Disconnected"; then
        echo -e "${GREEN}${dot}подключен${RESET}"
    else
        echo -e "${RED}${dot}отключен${RESET}"
    fi
}

modules_menu() {
    while true; do
        local mieru_status="${RED}отключен${RESET}"
        if is_mieru_enabled; then
            mieru_status="${GREEN}включен${RESET}"
        fi
        
        local netbird_status
        netbird_status=$(get_netbird_status "true")
        
        local sb_status="${RED}отключен${RESET}"
        if systemctl is-active --quiet sing-box; then
            sb_status="${GREEN}включен${RESET}"
        fi
        
        local options=(
            "Mieru       [$mieru_status]"
            "NetBird     [$netbird_status]"
            "sing-box    [$sb_status]"
            "Назад"
        )
        select_menu SELECTED_INDEX "Модули" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            mieru_module_menu
        elif [ "$choice" -eq 1 ]; then
            netbird_module_menu
        elif [ "$choice" -eq 2 ]; then
            singbox_module_menu
        elif [ "$choice" -eq 3 ] || [ "$choice" -eq -1 ]; then
            return 0
        fi
    done
}

singbox_module_menu() {
    while true; do
        clear_screen
        print_header "Модули → sing-box" "false"
        
        local status_label="${RED}отключен${RESET}"
        if systemctl is-active --quiet sing-box; then
            status_label="${GREEN}включен${RESET}"
        fi
        
        echo -e "  Состояние sing-box:"
        echo -e "  • Статус:          $status_label"
        draw_line "─" "$BLUE"
        
        local options=()
        if systemctl is-active --quiet sing-box; then
            options+=(
                "Остановить службу"
                "Перезапустить службу"
            )
        else
            options+=(
                "Запустить службу"
            )
        fi
        
        options+=(
            "Просмотреть логи службы"
            "Обновить sing-box"
            "Назад"
        )
        
        select_menu SELECTED_INDEX "Модуль: sing-box" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        local selected_option="${options[$choice]}"
        local clean_sel
        clean_sel=$(printf "%b" "$selected_option" | sed 's/\x1b\[[0-9;]*m//g')
        
        if [ "$choice" -eq -1 ] || [ "$clean_sel" == "Назад" ]; then
            return 0
        elif [ "$clean_sel" == "Запустить службу" ]; then
            echo -e "\n  [*] Запуск службы sing-box..."
            systemctl start sing-box
            echo ""
            center_print "${GREEN}✓ Служба sing-box запущена.${RESET}"
            pause
        elif [ "$clean_sel" == "Остановить службу" ]; then
            echo -e "\n  [*] Остановка службы sing-box..."
            systemctl stop sing-box
            echo ""
            center_print "${GREEN}✓ Служба sing-box остановлена.${RESET}"
            pause
        elif [ "$clean_sel" == "Перезапустить службу" ]; then
            echo -e "\n  [*] Перезапуск службы sing-box..."
            systemctl restart sing-box
            echo ""
            center_print "${GREEN}✓ Служба sing-box перезапущена.${RESET}"
            pause
        elif [ "$clean_sel" == "Просмотреть логи службы" ]; then
            clear_screen
            print_header "Модули → sing-box → Логи службы" "false"
            journalctl -u sing-box -n 50 --no-pager || true
            pause
        elif [ "$clean_sel" == "Обновить sing-box" ]; then
            update_singbox_menu
        fi
    done
}

install_mieru() {
    echo -e "  [*] Поиск последней версии mita (Mieru)..."
    local latest_mita_ver
    latest_mita_ver=$(curl -fsSL https://api.github.com/repos/enfein/mieru/releases/latest | jq -r .tag_name || true)
    if [ -z "$latest_mita_ver" ] || [ "$latest_mita_ver" == "null" ]; then
        latest_mita_ver="v3.34.0" # Fallback
    fi
    local clean_mita_ver=${latest_mita_ver#v}
    
    local go_arch="amd64"
    local arch_raw
    arch_raw=$(uname -m)
    if [ "$arch_raw" == "x86_64" ]; then
        go_arch="amd64"
    elif [ "$arch_raw" == "aarch64" ]; then
        go_arch="arm64"
    fi
    
    local deb_mita_url="https://github.com/enfein/mieru/releases/download/${latest_mita_ver}/mita_${clean_mita_ver}_${go_arch}.deb"
    echo -e "  [*] Скачивание пакета с официального GitHub: $deb_mita_url"
    local tmp_deb
    tmp_deb=$(mktemp)
    if wget -qO "$tmp_deb" "$deb_mita_url"; then
        echo -e "  [*] Установка пакета..."
        dpkg -i "$tmp_deb" >/dev/null
        rm -f "$tmp_deb"
        
        systemctl daemon-reload
        systemctl enable mita >/dev/null 2>&1 || true
        
        # Re-render configurations
        python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
        echo ""
        center_print "${GREEN}✓ Mieru (Mita) успешно установлен!${RESET}"
    else
        echo ""
        center_print "${RED}✗ Не удалось скачать пакет Mieru. Проверьте интернет-соединение.${RESET}"
    fi
}

uninstall_mieru() {
    echo -e "  [*] Останавливаем и отключаем службу..."
    systemctl stop mita >/dev/null 2>&1 || true
    systemctl disable mita >/dev/null 2>&1 || true
    echo -e "  [*] Удаление пакета..."
    dpkg -P mita >/dev/null 2>&1 || true
    rm -rf /etc/mita
    rm -f /etc/systemd/system/mita.service.d/override.conf
    systemctl daemon-reload
    
    if grep -q "^MIERU_ENABLED=" ${PROJECT_ROOT}/instance.env; then
        sed -i "s/^MIERU_ENABLED=.*/MIERU_ENABLED=false/" ${PROJECT_ROOT}/instance.env
    fi
    
    # Re-render configurations
    python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
    echo ""
    center_print "${GREEN}✓ Mieru (Mita) успешно удален.${RESET}"
}

