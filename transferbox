    local confirm
    if [ "$current" == "$latest" ]; then
        echo -e "  ${GREEN}вЬУ –£ –≤–∞—Б —Г–ґ–µ —Г—Б—В–∞–љ–Њ–≤–ї–µ–љ–∞ –њ–Њ—Б–ї–µ–і–љ—П—П –Њ—Д–Є—Ж–Є–∞–ї—М–љ–∞—П –≤–µ—А—Б–Є—П.${RESET}"
        read_prompt "–•–Њ—В–Є—В–µ –њ–µ—А–µ—Г—Б—В–∞–љ–Њ–≤–Є—В—М/–њ—А–Є–љ—Г–і–Є—В–µ–ї—М–љ–Њ –Њ–±–љ–Њ–≤–Є—В—М –≤–µ—А—Б–Є—О $latest? [y/N]: " confirm
    else
        echo -e "  ${YELLOW}вЪ† –Ф–Њ—Б—В—Г–њ–љ–Њ –Њ–±–љ–Њ–≤–ї–µ–љ–Є–µ –і–Њ –≤–µ—А—Б–Є–Є $latest!${RESET}"
        read_prompt "–Я—А–Њ–і–Њ–ї–ґ–Є—В—М –Њ–±–љ–Њ–≤–ї–µ–љ–Є–µ? [y/N]: " confirm
    fi
    
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
        echo -e "\n  [*] –Ч–∞–њ—Г—Б–Ї –њ—А–Њ—Ж–µ—Б—Б–∞ –Њ–±–љ–Њ–≤–ї–µ–љ–Є—П –і–Њ –≤–µ—А—Б–Є–Є $latest..."
