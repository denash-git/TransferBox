            python3 -c "from core.config_manager import load_env, save_env; env = load_env(); env['VLESS_GRPC_SERVICE'] = '$val'; save_env(env)"
            changed=true
        elif [ "$choice" -eq 2 ]; then
            local val
            read_prompt "Введите путь XHTTP (должен начинаться со слэша /): " val
            val="${val// /}"
            if [[ "$val" == /* ]]; then
                python3 -c "from core.config_manager import load_env, save_env; env = load_env(); env['VLESS_XHTTP_PATH'] = '$val'; save_env(env)"
                changed=true
            else
