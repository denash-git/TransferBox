users_menu() {
    while true; do
        local options=(
            "–°–њ–Є—Б–Њ–Ї –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–µ–є"
            "–Ф–Њ–±–∞–≤–Є—В—М –љ–Њ–≤–Њ–≥–Њ –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—П"
            "–Э–∞–Ј–∞–і"
        )
        select_menu "–Я–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–Є" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            list_users_menu
        elif [ "$choice" -eq 1 ]; then
            create_user_menu
        elif [ "$choice" -eq 2 ] || [ "$choice" -eq -1 ]; then
            return 0
        fi
