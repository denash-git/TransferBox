list_users_menu() {
    while true; do
        if [ ! -f "/opt/transferbox/users.json" ] || [ "$(jq '. | length' /opt/transferbox/users.json 2>/dev/null)" -eq 0 ]; then
            clear_screen
            print_header "Список пользователей"
            echo -e "  Пользователей пока нет."
            pause
            return 0
        fi
        
        # Считывание уникальных пользователей и списка их протоколов
        local users_raw=()
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            users_raw+=("$line")
        done < <(jq -r 'group_by(.nickname)[] | "\((.[0].nickname))|\(map(if .protocol == "naive" then "Naive" else if .protocol == "mieru" then "Mieru" else "VLESS " + (if .credentials.type == "ws" then "WS" else if .credentials.type == "grpc" then "gRPC" else if .credentials.type == "xhttp" then "XHTTP" else .credentials.type end end end) end end) | join(", "))"' /opt/transferbox/users.json 2>/dev/null)
        
        local options=()
        local nicknames=()
        local max_nick_len=0
        
        for u in "${users_raw[@]}"; do
            IFS='|' read -r nick protos <<< "$u"
            nicknames+=("$nick")
            if [ ${#nick} -gt $max_nick_len ]; then
                max_nick_len=${#nick}
            fi
        done
        
        local col_width=$(( max_nick_len + 4 ))
        for u in "${users_raw[@]}"; do
            IFS='|' read -r nick protos <<< "$u"
            local pad_spaces=""
            local pad_len=$(( col_width - ${#nick} ))
            if [ $pad_len -gt 0 ]; then
                pad_spaces=$(printf "%${pad_len}s" "")
            fi
            options+=("$nick$pad_spaces(Протоколы: $protos)")
        done
        options+=("Назад")
        
        select_menu "Список пользователей" "${options[@]}"
        local choice=$SELECTED_INDEX
        
