run_speedtest_vps_internet() {
    # Check if official speedtest is installed, if not install it
    if ! dpkg -s speedtest >/dev/null 2>&1; then
        clear_screen
        print_header "Скорость VPS → Интернет" "false"
        echo -e "  [*] Установка официального Ookla Speedtest..."
        sudo apt-get purge -y speedtest-cli >/dev/null 2>&1 || true
        sudo apt-get install -f -y >/dev/null 2>&1 || true
        curl -s https://packagecloud.io/install/repositories/ookla/speedtest-cli/script.deb.sh | sudo bash >/dev/null 2>&1
        sudo apt-get install -y speedtest >/dev/null 2>&1
    fi

    if ! command -v speedtest >/dev/null 2>&1; then
        echo -e "  ${RED}✗ Не удалось установить speedtest.${RESET}"
        pause
        return 0
    fi

    while true; do
        local options=(
            "Тест на ближайшем сервере (автовыбор)"
            "Выбрать сервер из списка ближайших"
            "Назад"
        )
        select_menu "VPS → Интернет" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            clear_screen
            print_header "Скорость VPS → Интернет (Автовыбор)" "false"
            echo -e "  ${CYAN}Запуск теста, подождите...${RESET}\n"
            speedtest --accept-license --accept-gdpr 2>&1 | sed 's/^/  /'
            echo
            pause
            return 0
        elif [ "$choice" -eq 1 ]; then
            clear_screen
            print_header "Поиск ближайших серверов" "false"
            echo -e "  [*] Получение списка серверов..."
            
            local servers_raw=()
            while IFS= read -r line; do
                [ -z "$line" ] && continue
                if [[ "$line" =~ ^[[:space:]]*([0-9]+)[[:space:]]+(.*)$ ]]; then
                    servers_raw+=("${BASH_REMATCH[1]}|${BASH_REMATCH[2]}")
                fi
            done < <(speedtest -L --accept-license --accept-gdpr 2>/dev/null)
            
            if [ ${#servers_raw[@]} -eq 0 ]; then
                echo -e "\n  ${RED}✗ Не удалось получить список серверов.${RESET}"
                pause
                continue
            fi
            
            local select_opts=()
            local select_ids=()
            for s in "${servers_raw[@]}"; do
                IFS='|' read -r id details <<< "$s"
                details=$(echo "$details" | tr -s ' ')
                select_opts+=("[$id] $details")
                select_ids+=("$id")
            done
            select_opts+=("Назад")
            
            select_menu "Выберите сервер" "${select_opts[@]}"
            local sel_choice=$SELECTED_INDEX
            
            if [ "$sel_choice" -eq -1 ] || [ "$sel_choice" -eq $(( ${#select_opts[@]} - 1 )) ]; then
                continue
            fi
            
            local selected_id="${select_ids[$sel_choice]}"
            local selected_name="${select_opts[$sel_choice]}"
            
            clear_screen
            print_header "VPS → Интернет ($selected_name)" "false"
            echo -e "  ${CYAN}Запуск теста на сервере $selected_id, подождите...${RESET}\n"
            speedtest -s "$selected_id" --accept-license --accept-gdpr 2>&1 | sed 's/^/  /'
            echo
            pause
            return 0
        else
            return 0
        fi
    done
}
run_speedtest_client_vps() {
    clear_screen
    print_header "Замер скорости: Client ↔ VPS (iperf3)" "false"
    
    if ! command -v iperf3 >/dev/null 2>&1; then
        echo ""
        center_print "${DIM}[*] Установка iperf3 на VPS...${RESET}"
        sudo apt-get update >/dev/null 2>&1
        sudo apt-get install -y iperf3 >/dev/null 2>&1
    fi
    
    # Open UFW port temporarily
    sudo ufw allow 5201/tcp comment "iperf3 TCP" >/dev/null 2>&1
    sudo ufw allow 5201/udp comment "iperf3 UDP" >/dev/null 2>&1
    
    local vps_ip
    vps_ip=$(curl -s ifconfig.me || curl -s api.ipify.org || echo "IP вашего VPS")
    
    echo ""
    center_print "Запуск iperf3 сервера на VPS..."
    echo ""
    center_print "Для тестирования запустите на клиенте (ПК):"
    center_print "${CYAN}iperf3 -c $vps_ip${RESET}"
    echo ""
    center_print "Для теста в обратную сторону (отдача от VPS к клиенту):"
    center_print "${CYAN}iperf3 -c $vps_ip -R${RESET}"
    echo ""
    center_print "На телефоне используйте приложения ${YELLOW}Magic iPerf${RESET} (Android)"
    center_print "или ${YELLOW}HE.NET Network Tools${RESET} (iOS) с адресом сервера ${CYAN}$vps_ip${RESET}."
    echo ""
    center_print "${DIM}Для отмены и возврата в меню нажмите Ctrl+C.${RESET}"
    echo ""
    draw_line "─" "$BLUE"
    echo ""
    
    # Run iperf3 server for 1 client session, catch Ctrl+C to return to menu gracefully
    (
        trap 'exit 0' INT
        iperf3 -s -1
    )
    
    # Remove firewall rules on exit
    sudo ufw delete allow 5201/tcp >/dev/null 2>&1
    sudo ufw delete allow 5201/udp >/dev/null 2>&1
    
    echo ""
    center_print "${GREEN}Тестирование завершено.${RESET}"
    pause
}
