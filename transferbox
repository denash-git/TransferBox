system_monitor_menu() {
    tput civis
    clear_screen

    local iface
    iface=$(ip route | grep default | awk '{print $5}' | head -n 1)
    [ -z "$iface" ] && iface="eth0"

    # Helper: draw a progress bar
    # usage: _mon_bar <pct_int> <color>
    _mon_bar() {
        local pct=$1 color=$2
        local filled=$(( pct * 20 / 100 ))
        local empty=$(( 20 - filled ))
        printf "${color}"
        for ((i=0;i<filled;i++)); do printf "█"; done
        printf "${RESET}${DIM}"
        for ((i=0;i<empty;i++)); do printf "░"; done
        printf "${RESET}"
    }

    # Helper: color by thresholds
    _mon_color() {
        local pct=$1
        if   [ "$pct" -ge 85 ]; then echo "$RED"
        elif [ "$pct" -ge 60 ]; then echo "$YELLOW"
        else echo "$GREEN"
        fi
    }

    # Helper: format bytes/s → KB/s or MB/s
    _mon_speed() {
        local kb=$1
        if [ "$kb" -gt 1024 ]; then
            local mb
            mb=$(echo "scale=1; $kb/1024" | bc 2>/dev/null || echo "$(( kb/1024 ))")
            echo "${mb} MB/s"
        else
            echo "${kb} KB/s"
        fi
    }

    # Center-pad a string to given width (no color codes in width calc)
    _mon_pad() {
        local str="$1" width="$2"
        # strip ANSI for length calc
        local plain
        plain=$(printf '%s' "$str" | sed 's/\x1b\[[0-9;]*m//g')
        local len=${#plain}
        local pad=$(( (width - len) / 2 ))
        [ "$pad" -lt 0 ] && pad=0
        printf "%${pad}s%s" "" "$str"
    }

    while true; do
        # ── Sample 1
        local cpu_stat1
        cpu_stat1=$(grep '^cpu ' /proc/stat)
        local stats1=($cpu_stat1)
        local idle1=${stats1[4]}
        local total1=0
        for v in "${stats1[@]:1}"; do total1=$(( total1+v )); done

        local net1
        net1=$(grep "${iface}:" /proc/net/dev | awk '{print $2" "$10}')
        local rx1=$(echo "$net1" | awk '{print $1}')
        local tx1=$(echo "$net1" | awk '{print $2}')

        # ── Wait 1s, detect key
        local key=""
        if read -t 1 -rsn1 key; then
            if [[ "$key" == "q" || "$key" == "Q" || "$key" == "0" || "$key" == "" ]]; then
                tput cnorm; return 0
            fi
        fi

        # ── Sample 2
        local cpu_stat2
        cpu_stat2=$(grep '^cpu ' /proc/stat)
        local stats2=($cpu_stat2)
        local idle2=${stats2[4]}
        local total2=0
        for v in "${stats2[@]:1}"; do total2=$(( total2+v )); done

        local net2
        net2=$(grep "${iface}:" /proc/net/dev | awk '{print $2" "$10}')
        local rx2=$(echo "$net2" | awk '{print $1}')
        local tx2=$(echo "$net2" | awk '{print $2}')

        # ── CPU %
        local diff_idle=$(( idle2-idle1 ))
        local diff_total=$(( total2-total1 ))
        local cpu_pct=0
        [ "$diff_total" -gt 0 ] && cpu_pct=$(( (diff_total-diff_idle)*100/diff_total ))

        # ── RAM
        local ram_total ram_used ram_free ram_cache ram_pct
        ram_total=$(free -m | awk '/Mem:/{print $2}')
        ram_used=$(free -m  | awk '/Mem:/{print $3}')
        ram_free=$(free -m  | awk '/Mem:/{print $4}')
        ram_cache=$(free -m | awk '/Mem:/{print $6}')
        ram_pct=$(( ram_used*100/ram_total ))

        # ── Disk
        local disk_total disk_used disk_pct_str disk_pct_int
        disk_total=$(df -h / | awk 'NR==2{print $2}')
        disk_used=$(df -h /  | awk 'NR==2{print $3}')
        disk_pct_str=$(df -h / | awk 'NR==2{print $5}')
        disk_pct_int=$(df /   | awk 'NR==2{print $5}' | tr -d '%')

        # ── Net
        local rx_kb=$(( (rx2-rx1)/1024 ))
        local tx_kb=$(( (tx2-tx1)/1024 ))
        local rx_str tx_str
        rx_str=$(_mon_speed $rx_kb)
        tx_str=$(_mon_speed $tx_kb)

        # ── Uptime & Load
        local uptime_str load_str
        uptime_str=$(uptime -p 2>/dev/null | sed 's/up //' || uptime | awk -F'up |,' '{print $2}' | xargs)
        load_str=$(awk '{print $1" "$2" "$3}' /proc/loadavg)

        # ── Colors
        local cpu_col ram_col disk_col
        cpu_col=$(_mon_color $cpu_pct)
        ram_col=$(_mon_color $ram_pct)
        disk_col=$(_mon_color $disk_pct_int)

        # ── Draw dashboard
        printf "\033[H"
        print_header "Мониторинг ресурсов" "false"
        echo ""

        local cpu_bar; cpu_bar=$(_mon_bar $cpu_pct "$cpu_col")
        local ram_bar; ram_bar=$(_mon_bar $ram_pct "$ram_col")
        local disk_bar; disk_bar=$(_mon_bar $disk_pct_int "$disk_col")

        local term_width
        term_width=$(tput cols 2>/dev/null || echo 80)
        local indent=$(( (term_width - 68) / 2 ))
        [ "$indent" -lt 2 ] && indent=2

        # ── Separator helper (fixed 68 chars)
        local SEP="${DIM}────────────────────────────────────────────────────────────────────${RESET}"

        # ── CPU | RAM
        printf "%${indent}s%b▸ CPU%b%-32s%b▸ RAM%b\n" "" "$BOLD$BLUE" "$RESET" "" "$BOLD$BLUE" "$RESET"
        printf "%${indent}s%b %b%3d%%%b%-21s%b %b%3d%%%b\n" "" \
               "$cpu_bar" "$cpu_col$BOLD" "$cpu_pct" "$RESET" "" "$ram_bar" "$ram_col$BOLD" "$ram_pct" "$RESET"
        printf "%${indent}s%bLoad avg:%b %b%-27s%b" "" "$DIM" "$RESET" "$CYAN" "$load_str" "$RESET"
        printf "%b%s%b/%s MB  св:%b%s%b кэш:%b%s%b MB\n" \
               "$CYAN" "$ram_used" "$RESET" "$ram_total" "$GREEN" "$ram_free" "$RESET" "$DIM" "$ram_cache" "$RESET"

        echo ""
        center_print "$SEP"
        echo ""

        # ── DISK | NETWORK
        printf "%${indent}s%b▸ DISK (/)%b%-27s" "" "$BOLD$BLUE" "$RESET" ""
        printf "%b▸ NETWORK%b  %b(%s)%b\n" "$BOLD$BLUE" "$RESET" "$DIM" "$iface" "$RESET"
        printf "%${indent}s%b %b%-6s%b%-17s" "" "$disk_bar" "$disk_col$BOLD" "$disk_pct_str" "$RESET" ""
        printf "%b↓ RX:%b %b%-12s%b  %b↑ TX:%b %b%s%b\n" \
               "$DIM" "$RESET" "$GREEN$BOLD" "$rx_str" "$RESET" "$DIM" "$RESET" "$YELLOW$BOLD" "$tx_str" "$RESET"
        printf "%${indent}s%bИспользовано:%b %b%s%b %bиз%b %s\n" "" \
               "$DIM" "$RESET" "$CYAN" "$disk_used" "$RESET" "$DIM" "$RESET" "$disk_total"

        echo ""
        center_print "$SEP"
        center_print "${DIM}Аптайм: ${RESET}${CYAN}${uptime_str}${RESET}"
        echo ""
        center_print "$SEP"
        center_print "${DIM}[Q / Enter — вернуться в меню]${RESET}"
        printf "%b" "\033[J"
    done
}


# Запуск главного меню
main_menu
