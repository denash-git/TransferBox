install_mieru() {
    echo -e "  [*] –Я–Њ–Є—Б–Ї –њ–Њ—Б–ї–µ–і–љ–µ–є –≤–µ—А—Б–Є–Є mita (Mieru)..."
    local latest_mita_ver
    latest_mita_ver=$(curl -fsSL https://api.github.com/repos/enfein/mieru/releases/latest | jq -r .tag_name || true)
    if [ -z "$latest_mita_ver" ] || [ "$latest_mita_ver" == "null" ]; then
        latest_mita_ver="v3.34.0" # Fallback
    fi
    local clean_mita_ver=${latest_mita_ver#v}
    
    local go_arch="amd64"
    local arch_raw
    arch_raw=$(uname -m)
    if [ "$arch_raw" == "x86_64" ]; then
        go_arch="amd64"
    elif [ "$arch_raw" == "aarch64" ]; then
        go_arch="arm64"
    fi
    
    local deb_mita_url="https://github.com/enfein/mieru/releases/download/${latest_mita_ver}/mita_${clean_mita_ver}_${go_arch}.deb"
    echo -e "  [*] –°–Ї–∞—З–Є–≤–∞–љ–Є–µ –њ–∞–Ї–µ—В–∞ —Б –Њ—Д–Є—Ж–Є–∞–ї—М–љ–Њ–≥–Њ GitHub: $deb_mita_url"
    if wget -qO /tmp/mita.deb "$deb_mita_url"; then
        echo -e "  [*] –£—Б—В–∞–љ–Њ–≤–Ї–∞ –њ–∞–Ї–µ—В–∞..."
        dpkg -i /tmp/mita.deb >/dev/null
        rm -f /tmp/mita.deb
        
        systemctl daemon-reload
        systemctl enable mita >/dev/null 2>&1 || true
        
        # Re-render configurations
        python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
        echo ""
        center_print "${GREEN}вЬУ Mieru (Mita) —Г—Б–њ–µ—И–љ–Њ —Г—Б—В–∞–љ–Њ–≤–ї–µ–љ!${RESET}"
    else
        echo ""
        center_print "${RED}вЬЧ –Э–µ —Г–і–∞–ї–Њ—Б—М —Б–Ї–∞—З–∞—В—М –њ–∞–Ї–µ—В Mieru. –Я—А–Њ–≤–µ—А—М—В–µ –Є–љ—В–µ—А–љ–µ—В-—Б–Њ–µ–і–Є–љ–µ–љ–Є–µ.${RESET}"
    fi
}

uninstall_mieru() {
    echo -e "  [*] –Ю—Б—В–∞–љ–∞–≤–ї–Є–≤–∞–µ–Љ –Є –Њ—В–Ї–ї—О—З–∞–µ–Љ —Б–ї—Г–ґ–±—Г..."
    systemctl stop mita >/dev/null 2>&1 || true
    systemctl disable mita >/dev/null 2>&1 || true
    echo -e "  [*] –£–і–∞–ї–µ–љ–Є–µ –њ–∞–Ї–µ—В–∞..."
    dpkg -P mita >/dev/null 2>&1 || true
    rm -rf /etc/mita
    rm -f /etc/systemd/system/mita.service.d/override.conf
    systemctl daemon-reload
    
    if grep -q "^MIERU_ENABLED=" /opt/transferbox/instance.env; then
        sed -i "s/^MIERU_ENABLED=.*/MIERU_ENABLED=false/" /opt/transferbox/instance.env
    fi
    
    # Re-render configurations
    python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
    echo ""
    center_print "${GREEN}вЬУ Mieru (Mita) —Г—Б–њ–µ—И–љ–Њ —Г–і–∞–ї–µ–љ.${RESET}"
}

