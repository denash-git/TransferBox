update_panel_menu() {
    clear_screen
    print_header "Настройки → Обновление панели" "false"
    echo -e "  [*] Проверка обновлений на GitHub..."
    
    # Временно отключаем строгий режим для сетевого запроса и grep
    set +euo pipefail
    
    local tmp_version
    tmp_version=$(mktemp)
    
    local http_code
    http_code=$(curl -s -o "$tmp_version" -w "%{http_code}" --connect-timeout 5 https://raw.githubusercontent.com/denash-git/TransferBox/main/transferbox)
    local curl_status=$?
    
    local latest=""
    if [ $curl_status -eq 0 ] && [ "$http_code" == "200" ]; then
        if grep -q -E "^VERSION=" "$tmp_version"; then
            latest=$(grep -E "^VERSION=" "$tmp_version" | head -n1 | cut -d'"' -f2)
        fi
    fi
    rm -f "$tmp_version"
    
    # Восстанавливаем строгий режим
    set -euo pipefail
    
    if [ $curl_status -ne 0 ] || [ "$http_code" != "200" ]; then
        echo -e "\n  ${RED}✗ Не удалось подключиться к GitHub для проверки обновлений (HTTP код: ${http_code:-000}).${RESET}"
        pause
        return 0
    fi
    
    if [ -z "$latest" ]; then
        echo -e "\n  ${RED}✗ Файл версии на GitHub не содержит корректного тега версии (возможно, кэш CDN).${RESET}"
        pause
        return 0
    fi
    
    echo -e "  • Текущая версия: ${CYAN}${VERSION}${RESET}"
    echo -e "  • Свежая версия:  ${CYAN}${latest}${RESET}"
    
    if [ "$latest" == "$VERSION" ]; then
        echo -e "\n  ${GREEN}✓ У вас установлена актуальная версия панели.${RESET}"
        pause
        return 0
    fi
    
    if [ "$(printf '%s\n' "$VERSION" "$latest" | sort -V | head -n 1)" == "$VERSION" ]; then
        echo ""
        local confirm
        read_prompt "Доступно обновление до версии $latest. Обновить панель? [y/N]: " confirm
        if [[ "$confirm" =~ ^[yYдД]$ ]]; then
            clear_screen
            print_header "Настройки → Обновление панели" "false"
            echo -e "  [*] Создание резервной копии данных..."
            
            # Делаем бэкап данных и кода самой панели
            cp "${PROJECT_ROOT}/users.json" "${PROJECT_ROOT}/users.json.bak" 2>/dev/null || true
            cp "${PROJECT_ROOT}/instance.env" "${PROJECT_ROOT}/instance.env.bak" 2>/dev/null || true
            cp "${PROJECT_ROOT}/transferbox" "${PROJECT_ROOT}/transferbox.bak" 2>/dev/null || true
            
            echo -e "  [*] Загрузка архива версии v$latest..."
            local tmp_dir
            tmp_dir=$(mktemp -d)
            
            if wget -qO "$tmp_dir/tb.tar.gz" "https://github.com/denash-git/TransferBox/archive/refs/tags/v${latest}.tar.gz" && \
               tar -xzf "$tmp_dir/tb.tar.gz" -C "$tmp_dir" --strip-components=1; then
                
                # Проверка структуры распакованного архива
                if [ ! -f "$tmp_dir/transferbox" ]; then
                    echo -e "\n  ${RED}✗ Ошибка: Архив имеет неожиданную структуру (файл transferbox не найден).${RESET}"
                    # Восстанавливаем бэкапы
                    rm -f "${PROJECT_ROOT}/users.json.bak" "${PROJECT_ROOT}/instance.env.bak" "${PROJECT_ROOT}/transferbox.bak"
                    rm -rf "$tmp_dir"
                    pause
                    return 0
                fi
                
                echo -e "  [*] Проверка целостности и синтаксиса файлов..."
                if bash -n "$tmp_dir/transferbox" && bash -n "$tmp_dir/install.sh" && python3 -m py_compile "$tmp_dir/core/config_manager.py" "$tmp_dir/core/user_manager.py"; then
                    echo -e "  [*] Установка обновлений..."
                    
                    # Создаем бэкап папки core на всякий случай
                    cp -r "$PROJECT_ROOT/core" "$PROJECT_ROOT/core.bak" 2>/dev/null || true
                    
                    cp -r "$tmp_dir/core" "$tmp_dir/templates" "$tmp_dir/lib" "$PROJECT_ROOT/"
                    cp "$tmp_dir/transferbox" "$PROJECT_ROOT/"
                    cp "$tmp_dir/transferbox" /usr/local/bin/menu
                    chmod +x /usr/local/bin/menu
                    
                    echo -e "  [*] Запуск миграций и валидация конфигураций..."
                    local migration_res
                    migration_res=$(python3 -c "
from core.config_manager import run_migrations, render_configs, validate_and_restart
run_migrations()
render_configs()
success, msg = validate_and_restart()
print('SUCCESS' if success else 'ERROR:' + msg)
" 2>&1)
                    
                    if [[ "$migration_res" == "SUCCESS" ]]; then
                        echo -e "\n  ${GREEN}✓ Обновление до версии $latest успешно завершено!${RESET}"
                        echo -e "  Панель управления будет перезапущена..."
                        # Очищаем бэкапы при успехе
                        rm -f "${PROJECT_ROOT}/users.json.bak" "${PROJECT_ROOT}/instance.env.bak" "${PROJECT_ROOT}/transferbox.bak"
                        rm -rf "$PROJECT_ROOT/core.bak"
                        rm -f "${PROJECT_ROOT}/.tb_update_cache"
                        rm -rf "$tmp_dir"
                        pause
                        exec /usr/local/bin/menu
                    else
                        echo -e "\n  ${RED}✗ Ошибка применения конфигураций после обновления:${RESET}"
                        echo -e "  ${migration_res#ERROR:}"
                        echo -e "\n  [*] Восстановление данных из резервной копии..."
                        # Восстанавливаем резервные копии
                        [ -f "${PROJECT_ROOT}/users.json.bak" ] && mv "${PROJECT_ROOT}/users.json.bak" "${PROJECT_ROOT}/users.json"
                        [ -f "${PROJECT_ROOT}/instance.env.bak" ] && mv "${PROJECT_ROOT}/instance.env.bak" "${PROJECT_ROOT}/instance.env"
                        if [ -f "${PROJECT_ROOT}/transferbox.bak" ]; then
                            mv "${PROJECT_ROOT}/transferbox.bak" "${PROJECT_ROOT}/transferbox"
                            cp "${PROJECT_ROOT}/transferbox" /usr/local/bin/menu
                        fi
                        if [ -d "$PROJECT_ROOT/core.bak" ]; then
                            rm -rf "$PROJECT_ROOT/core"
                            mv "$PROJECT_ROOT/core.bak" "$PROJECT_ROOT/core"
                        fi
                        rm -rf "$tmp_dir"
                        pause
                    fi
                else
                    echo -e "\n  ${RED}✗ Ошибка проверки целостности загруженных файлов (синтаксический сбой).${RESET}"
                    # Восстанавливаем бэкапы
                    rm -f "${PROJECT_ROOT}/users.json.bak" "${PROJECT_ROOT}/instance.env.bak" "${PROJECT_ROOT}/transferbox.bak"
                    rm -rf "$tmp_dir"
                    pause
                fi
            else
                echo -e "\n  ${RED}✗ Ошибка скачивания или распаковки архива версии v$latest.${RESET}"
                # Восстанавливаем бэкапы
                rm -f "${PROJECT_ROOT}/users.json.bak" "${PROJECT_ROOT}/instance.env.bak" "${PROJECT_ROOT}/transferbox.bak"
                rm -rf "$tmp_dir"
                pause
            fi
        fi
    else
        echo -e "\n  ${YELLOW}⚠️ Ваша версия ($VERSION) новее, чем версия в репозитории ($latest).${RESET}"
        pause
    fi
}

settings_menu() {
    while true; do
        if [ -f "${PROJECT_ROOT}/instance.env" ]; then
            source ${PROJECT_ROOT}/instance.env
        fi
        local domain="${DOMAIN:-не задан}"
        local email="${ADMIN_EMAIL:-не задан (анонимный SSL)}"
        [ -z "$email" ] && email="не задан (анонимный SSL)"
        local template="${FAKE_SITE_TEMPLATE:-aether}"
        local vless_ws="${VLESS_WS_PATH:-/}"
        local vless_grpc="${VLESS_GRPC_SERVICE:-(пусто)}"
        [ -z "$vless_grpc" ] && vless_grpc="(пусто)"
        local vless_xhttp="${VLESS_XHTTP_PATH:-/xhttp}"
        
        local ssh_port
        ssh_port=$(python3 -c "from core.config_manager import get_current_ssh_port; print(get_current_ssh_port())")
        
        local bbr_status="${RED}отключен${RESET}"
        if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q "bbr"; then
            bbr_status="${GREEN}активен${RESET}"
        fi
        
        local vps_fqdn
        vps_fqdn=$(hostname -f 2>/dev/null || hostname)
        
        clear_screen
        print_header "Настройки"
        echo -e "  Текущая конфигурация:"
        echo -e "  • Домен:             $domain"
        echo -e "  • Email Let's Encrypt: $email"
        echo -e "  • FQDN имя VPS:      $vps_fqdn"
        echo -e "  • Шаблон сайта:      $template"
        echo -e "  • Путь VLESS WS:     $vless_ws"
        echo -e "  • Сервис VLESS gRPC:  $vless_grpc"
        echo -e "  • Путь VLESS XHTTP:  $vless_xhttp"
        echo -e "  • Порт SSH:          $ssh_port"
        echo -e "  • TCP BBR:           $bbr_status"
        draw_line "─" "$BLUE"
        
        local options=(
            "Изменить Домен и Email"
            "Изменить FQDN имя VPS"
            "Выбрать шаблон маскировочного сайта"
            "Настроить пути VLESS"
            "Изменить порт SSH"
        )
        if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q "bbr"; then
            options+=("Отключить BBR оптимизацию")
        else
            options+=("Включить BBR оптимизацию")
        fi
        options+=(
            "Проверить обновления панели"
            "Назад"
        )
        
        select_menu SELECTED_INDEX "Настройки" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        local selected_option="${options[$choice]}"
        local clean_sel
        clean_sel=$(printf "%b" "$selected_option" | sed 's/\x1b\[[0-9;]*m//g')
        
        if [ "$choice" -eq -1 ] || [ "$clean_sel" == "Назад" ]; then
            return 0
        elif [ "$clean_sel" == "Изменить Домен и Email" ]; then
            change_domain_email_menu
        elif [ "$clean_sel" == "Изменить FQDN имя VPS" ]; then
            change_vps_fqdn_menu
        elif [ "$clean_sel" == "Выбрать шаблон маскировочного сайта" ]; then
            change_site_template_menu
        elif [ "$clean_sel" == "Настроить пути VLESS" ]; then
            change_vless_paths_menu
        elif [ "$clean_sel" == "Изменить порт SSH" ]; then
            change_ssh_port_menu
        elif [ "$clean_sel" == "Проверить обновления панели" ]; then
            update_panel_menu
        elif [ "$clean_sel" == "Включить BBR оптимизацию" ] || [ "$clean_sel" == "Отключить BBR оптимизацию" ]; then
            clear_screen
            print_header "Настройки → BBR Оптимизация"
            if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q "bbr"; then
                echo ""
                center_print "${DIM}[*] Отключение BBR оптимизации...${RESET}"
                if sysctl -w net.ipv4.tcp_congestion_control=cubic >/dev/null 2>&1; then
                    rm -f /etc/sysctl.d/99-transferbox-bbr.conf
                    sysctl --system >/dev/null 2>&1
                    python3 -c "from core.config_manager import load_env, save_env; env = load_env(); env['BBR_ENABLED'] = 'false'; save_env(env)"
                    echo ""
                    center_print "${GREEN}✓ BBR оптимизация успешно отключена (переключено на cubic).${RESET}"
                else
                    echo ""
                    center_print "${RED}✗ Ошибка при отключении BBR.${RESET}"
                fi
            else
                echo ""
                center_print "${DIM}[*] Включение BBR оптимизации...${RESET}"
                if modprobe tcp_bbr 2>/dev/null; then
                    sysctl -w net.core.default_qdisc=fq >/dev/null 2>&1
                    sysctl -w net.ipv4.tcp_congestion_control=bbr >/dev/null 2>&1
                    cat > /etc/sysctl.d/99-transferbox-bbr.conf <<EOF
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
EOF
                    sysctl --system >/dev/null 2>&1
                    python3 -c "from core.config_manager import load_env, save_env; env = load_env(); env['BBR_ENABLED'] = 'true'; save_env(env)"
                    echo ""
                    center_print "${GREEN}✓ BBR оптимизация успешно включена!${RESET}"
                else
                    echo ""
                    center_print "${RED}✗ Ошибка: Ядро вашей системы не поддерживает BBR.${RESET}"
                fi
            fi
            pause
        fi
    done
}

change_ssh_port_menu() {
    local cur_port
    cur_port=$(python3 -c "from core.config_manager import get_current_ssh_port; print(get_current_ssh_port())")
    
    clear_screen
    print_header "Настройки → Изменение порта SSH" "false"
    echo -e "  Текущий порт SSH: ${CYAN}$cur_port${RESET}"
    echo -e "  ${RED}⚠️ ВНИМАНИЕ: Изменение порта SSH — чувствительное действие.${RESET}"
    echo -e "  Мы автоматически настроим фаервол UFW, чтобы не заблокировать доступ,"
    echo -e "  но после изменения настоятельно рекомендуется проверить подключение"
    echo -e "  в новом окне терминала, не закрывая текущую сессию!\n"
    
    local new_port
    read_prompt "Введите новый порт SSH (1-65535, или Enter для отмены): " new_port
    if [ -z "$new_port" ]; then
        return 0
    fi
    
    # Валидация порта
    if ! [[ "$new_port" =~ ^[0-9]+$ ]] || [ "$new_port" -lt 1 ] || [ "$new_port" -gt 65535 ]; then
        echo -e "\n  ${RED}✗ Неверный порт! Допустимы значения от 1 до 65535.${RESET}"
        pause
        return 0
    fi
    
    if [ "$new_port" -eq "$cur_port" ]; then
        echo -e "\n  ${GREEN}✓ Введенный порт совпадает с текущим.${RESET}"
        pause
        return 0
    fi
    
    echo -e "\n  [*] Применение изменений..."
    local res
    res=$(python3 -c "
from core.config_manager import change_ssh_port
success, msg = change_ssh_port($new_port)
if success:
    print('SUCCESS')
else:
    print(msg)
")
    
    if [ "$res" == "SUCCESS" ]; then
        echo -e "\n  ${GREEN}✓ SSH успешно переведен на порт $new_port!${RESET}"
        echo -e "  ${RED}⚠️ ВАЖНО: Откройте НОВОЕ окно терминала и попробуйте подключиться:${RESET}"
        echo -e "  ${BOLD}ssh root@<IP_сервера> -p $new_port${RESET}"
        echo -e "  ${RED}НЕ ЗАКРЫВАЙТЕ текущее окно, пока не проверите подключение!${RESET}\n"
        
        local confirm
        read_prompt "Вы успешно подключились по новому порту? (y/n, по умолчанию y): " confirm
        [ -z "$confirm" ] && confirm="y"
        
        if [[ "$confirm" =~ ^[yYдД]$ ]]; then
            echo -e "\n  [*] Очистка старых правил UFW..."
            python3 -c "from core.config_manager import remove_old_ssh_port_ufw; remove_old_ssh_port_ufw($cur_port)"
            echo -e "  ${GREEN}✓ Правило UFW для старого порта $cur_port удалено.${RESET}"
        else
            echo -e "\n  ${YELLOW}⚠️ Внимание: старый порт SSH $cur_port оставлен открытым в UFW на всякий случай.${RESET}"
        fi
        pause
    else
        echo -e "\n  ${RED}✗ Ошибка: $res${RESET}"
        pause
    fi
}

change_vps_fqdn_menu() {
    clear_screen
    print_header "Настройки → FQDN имя VPS" "false"
    local cur_fqdn
    cur_fqdn=$(hostname -f 2>/dev/null || hostname)
    center_print "Текущее FQDN имя VPS: ${CYAN}$cur_fqdn${RESET}"
    echo ""
    
    local new_fqdn
    read_prompt "Введите новое FQDN имя VPS (или Enter для отмены): " new_fqdn
    new_fqdn="${new_fqdn// /}"
    
    if [ -z "$new_fqdn" ]; then
        echo ""
        center_print "${RED}✗ Отменено. Имя не изменено.${RESET}"
        pause
        return 0
    fi
    
    # Simple validation (must not contain spaces or special chars other than dot/dash)
    if [[ ! "$new_fqdn" =~ ^[a-zA-Z0-9.-]+$ ]]; then
        echo ""
        center_print "${RED}✗ Неверный формат! Допускаются только буквы, цифры, точки и дефисы.${RESET}"
        pause
        return 0
    fi
    
    echo ""
    center_print "${DIM}[*] Изменение системного имени хоста...${RESET}"
    local old_fqdn
    old_fqdn=$(hostname)
    
    if hostnamectl set-hostname "$new_fqdn" 2>/dev/null; then
        # Update /etc/hosts
        if [ -f /etc/hosts ]; then
            sed -i "s/\b$old_fqdn\b/$new_fqdn/g" /etc/hosts
        fi
        python3 -c "from core.config_manager import load_env, save_env; env = load_env(); env['FQDN'] = '$new_fqdn'; save_env(env)"
        echo ""
        center_print "${GREEN}✓ FQDN имя VPS успешно изменено на $new_fqdn!${RESET}"
    else
        echo ""
        center_print "${RED}✗ Не удалось изменить имя хоста.${RESET}"
    fi
    pause
}

