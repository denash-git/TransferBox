#!/usr/bin/env bash
# =============================================================================
# TransferBox — Bash-обертка для запуска меню управления
# =============================================================================
set -euo pipefail

# Путь к рабочему каталогу утилиты
PROJECT_ROOT="/opt/transferbox"

# Проверка запуска от root
if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo -e "\033[1;31mОшибка: Для запуска утилиты требуются права root. Используйте: sudo transferbox\033[0m" >&2
    exit 1
fi

# Убедимся, что путь находится в python path для импорта модулей
export PYTHONPATH="${PROJECT_ROOT}"

# Запуск меню
exec python3 "${PROJECT_ROOT}/core/menu.py" "$@"
