set -euo pipefail

# ANSI Colors
BLUE='\033[1;34m'
GREEN='\033[1;32m'
RED='\033[1;31m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

# –Я—А–Њ–≤–µ—А–Ї–∞ –Ј–∞–њ—Г—Б–Ї–∞ –Њ—В root
if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo -e "${RED}–Ю—И–Є–±–Ї–∞: –Ф–ї—П –Ј–∞–њ—Г—Б–Ї–∞ —Г—В–Є–ї–Є—В—Л —В—А–µ–±—Г—О—В—Б—П –њ—А–∞–≤–∞ root. –Ш—Б–њ–Њ–ї—М–Ј—Г–є—В–µ: sudo menu${RESET}" >&2
    exit 1
fi

PROJECT_ROOT="/opt/transferbox"
export PYTHONPATH="${PROJECT_ROOT}"

# вФАвФАвФА –Т–°–Я–Ю–Ь–Ю–У–Р–Ґ–Х–Ы–ђ–Э–Ђ–Х –§–£–Э–Ъ–¶–Ш–Ш вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА

clear_screen() {
    printf "\033[2J\033[H"
}

pause() {
    echo ""
    center_print "${DIM}–Э–∞–ґ–Љ–Є—В–µ –ї—О–±—Г—О –Ї–ї–∞–≤–Є—И—Г –і–ї—П –њ—А–Њ–і–Њ–ї–ґ–µ–љ–Є—П...${RESET}"
    read -rsn1
}

read_prompt() {
    local prompt_text="$1"
    local var_name="$2"
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    local indent=$(( (term_width - 50) / 2 ))
    [ $indent -lt 2 ] && indent=2
    printf "%${indent}s%s" "" "$prompt_text"
    read -r "$var_name"
}

center_print() {
    local text="$1"
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    
    local clean_text
    clean_text=$(printf "%b" "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local text_len=${#clean_text}
    
    local padding=$(( (term_width - text_len) / 2 ))
    [ $padding -lt 0 ] && padding=0
    
    printf "%${padding}s%b\n" "" "$text"
}

center_print_no_newline() {
    local text="$1"
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    
    local clean_text
    clean_text=$(printf "%b" "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local text_len=${#clean_text}
    
    local padding=$(( (term_width - text_len) / 2 ))
    [ $padding -lt 0 ] && padding=0
    
    printf "%${padding}s%b" "" "$text"
}

draw_line() {
    local char="$1"
    local color="$2"
    local line
    line=$(printf "${char}%.0s" {1..60})
    center_print "${color}${line}${RESET}"
}

get_service_status() {
    local service_name="$1"
    if systemctl is-active --quiet "$service_name" 2>/dev/null; then
        echo -e "${GREEN}вЧП —А–∞–±–Њ—В–∞–µ—В${RESET}"
    else
        local status
        status=$(systemctl is-active "$service_name" 2>/dev/null)
        [ -z "$status" ] && status="inactive"
        echo -e "${RED}вЧП –љ–µ –Ј–∞–њ—Г—Й–µ–љ ($status)${RESET}"
    fi
}

print_header() {
    local title="$1"
    local show_status="${2:-false}"
    local domain="–љ–µ –Ј–∞–і–∞–љ"
    if [ -f "/opt/transferbox/instance.env" ]; then
        domain=$(grep -E "^DOMAIN=" /opt/transferbox/instance.env | cut -d'=' -f2-)
    fi
    [ -z "$domain" ] && domain="–љ–µ –Ј–∞–і–∞–љ"
    
    local line_double
    line_double=$(printf "вХР%.0s" {1..60})
    local line_single
    line_single=$(printf "вФА%.0s" {1..60})
    
    center_print "${BLUE}${line_double}${RESET}"
    center_print "${YELLOW}${title}${RESET}"
    center_print "${BLUE}${line_single}${RESET}"
    if [ "$show_status" == "true" ]; then
        # –Т—Л—З–Є—Б–ї—П–µ–Љ –Љ–∞–Ї—Б–Є–Љ–∞–ї—М–љ—Г—О –і–ї–Є–љ—Г –і–ї—П –Ї—А–∞—Б–Є–≤–Њ–≥–Њ –≤—Л—А–∞–≤–љ–Є–≤–∞–љ–Є—П –≤ —Б—В–Њ–ї–±–Є–Ї
        local status_cad_raw
        status_cad_raw=$(get_service_status caddy | sed 's/\x1b\[[0-9;]*m//g')
        local status_sb_raw
        status_sb_raw=$(get_service_status sing-box | sed 's/\x1b\[[0-9;]*m//g')
        
        local len_dom=$(( 10 + ${#domain} ))
        local len_cad=$(( 10 + ${#status_cad_raw} ))
        local len_sb=$(( 10 + ${#status_sb_raw} ))
        
        local max_block_len=$len_dom
        [ $len_cad -gt $max_block_len ] && max_block_len=$len_cad
        [ $len_sb -gt $max_block_len ] && max_block_len=$len_sb
        
        local show_mieru=false
        if [ -f "/usr/bin/mita" ]; then
            show_mieru=true
            local status_mita_raw
            status_mita_raw=$(get_service_status mita | sed 's/\x1b\[[0-9;]*m//g')
            local len_mita=$(( 10 + ${#status_mita_raw} ))
            [ $len_mita -gt $max_block_len ] && max_block_len=$len_mita
        fi
        
        local show_netbird=false
        if command -v netbird &>/dev/null; then
            show_netbird=true
            local status_nb_raw
            status_nb_raw=$(get_netbird_status | sed 's/\x1b\[[0-9;]*m//g')
            local len_nb=$(( 10 + ${#status_nb_raw} ))
            [ $len_nb -gt $max_block_len ] && max_block_len=$len_nb
        fi
        
        local term_width
        term_width=$(tput cols 2>/dev/null || echo 80)
        local indent=$(( (term_width - max_block_len) / 2 ))
        [ $indent -lt 0 ] && indent=0
        local pad_spaces
        pad_spaces=$(printf "%${indent}s" "")
        
        echo -e "${pad_spaces}–Ф–Њ–Љ–µ–љ:    ${BOLD}${domain}${RESET}"
        echo -e "${pad_spaces}Caddy:    $(get_service_status caddy)"
        echo -e "${pad_spaces}sing-box: $(get_service_status sing-box)"
        if [ "$show_mieru" == "true" ]; then
            echo -e "${pad_spaces}Mieru:    $(get_service_status mita)"
        fi
        if [ "$show_netbird" == "true" ]; then
            echo -e "${pad_spaces}NetBird:  $(get_netbird_status)"
        fi
        center_print "${BLUE}${line_double}${RESET}"
    fi
    echo ""
}

# –§—Г–љ–Ї—Ж–Є—П –љ–∞–≤–Є–≥–∞—Ж–Є–Є —Б—В—А–µ–ї–Ї–∞–Љ–Є
# –£—Б—В–∞–љ–∞–≤–ї–Є–≤–∞–µ—В –њ–µ—А–µ–Љ–µ–љ–љ—Г—О SELECTED_INDEX
select_menu() {
    local title="$1"
    shift
    local options=("$@")
    local num_options=${#options[@]}
    local active_idx=0
    
    # –°–Ї—А—Л—В—М –Ї—Г—А—Б–Њ—А
    tput civis
    
    # –Ю—З–Є—Б—В–Є—В—М —Н–Ї—А–∞–љ –Њ–і–Є–љ —А–∞–Ј –њ—А–Є –≤—Е–Њ–і–µ –≤ –Љ–µ–љ—О
    clear_screen
    
    while true; do
        # –Я–µ—А–µ–Љ–µ—Б—В–Є—В—М –Ї—Г—А—Б–Њ—А –≤ –≤–µ—А—Е–љ–Є–є –ї–µ–≤—Л–є —Г–≥–Њ–ї
        printf "\033[H"
        
        # –Ю–њ—А–µ–і–µ–ї–Є–Љ, –њ–Њ–Ї–∞–Ј—Л–≤–∞—В—М –ї–Є —Б—В–∞—В—Г—Б –љ–∞ –Њ—Б–љ–Њ–≤–µ –Ј–∞–≥–Њ–ї–Њ–≤–Ї–∞
        local show_status="false"
        if [ "$title" == "TransferBox вАФ –Я–∞–љ–µ–ї—М –£–њ—А–∞–≤–ї–µ–љ–Є—П" ]; then
            show_status="true"
        fi
        
        print_header "$title" "$show_status"
        
        # –Ю–њ—А–µ–і–µ–ї–Є–Љ –Љ–∞–Ї—Б–Є–Љ–∞–ї—М–љ—Г—О –≤–Є–Ј—Г–∞–ї—М–љ—Г—О –і–ї–Є–љ—Г –≤–∞—А–Є–∞–љ—В–Њ–≤ –і–ї—П —Ж–µ–љ—В—А–Є—А–Њ–≤–∞–љ–Є—П –±–ї–Њ–Ї–∞
        local max_len=0
        for opt in "${options[@]}"; do
            local clean_opt
            clean_opt=$(printf "%b" "$opt" | sed 's/\x1b\[[0-9;]*m//g')
            if [ ${#clean_opt} -gt $max_len ]; then
                max_len=${#clean_opt}
            fi
        done
        
        local term_width
        term_width=$(tput cols 2>/dev/null || echo 80)
        local indent=$(( (term_width - max_len) / 2 ))
        [ $indent -lt 0 ] && indent=0
        
        for i in "${!options[@]}"; do
            local opt="${options[$i]}"
            local clean_opt
            clean_opt=$(printf "%b" "$opt" | sed 's/\x1b\[[0-9;]*m//g')
            
            # –Ф–Њ–±–∞–≤–Є–Љ –њ—Г—Б—В—Г—О —Б—В—А–Њ–Ї—Г –Љ–µ–ґ–і—Г –≤—Б–µ–Љ–Є –њ—Г–љ–Ї—В–∞–Љ–Є –Љ–µ–љ—О –і–ї—П –Ї—А—Г–њ–љ–Њ–≥–Њ/–њ—А–Њ—Б—В–Њ—А–љ–Њ–≥–Њ –≤–Є–і–∞
            if [ "$i" -ne 0 ]; then
                printf "\n"
            fi
            
            # –Ф–Њ–±–∞–≤–Є–Љ –µ—Й–µ –Њ–і–љ—Г –њ—Г—Б—В—Г—О —Б—В—А–Њ–Ї—Г –њ–µ—А–µ–і "–Э–∞–Ј–∞–і", "–Ю—В–Љ–µ–љ–∞", "–Т—Л—Е–Њ–і" –і–ї—П –і–Њ–њ–Њ–ї–љ–Є—В–µ–ї—М–љ–Њ–≥–Њ –Њ—В–і–µ–ї–µ–љ–Є—П
            if [[ "$clean_opt" =~ ^(–Э–∞–Ј–∞–і|–Ю—В–Љ–µ–љ–∞|–Т—Л—Е–Њ–і)$ ]] && [ "$i" -ne 0 ]; then
                printf "\n"
            fi
            
            # –°–і–µ–ї–∞–µ–Љ "–Э–∞–Ј–∞–і", "–Ю—В–Љ–µ–љ–∞", "–Т—Л—Е–Њ–і" –ґ–µ–ї—В—Л–Љ–Є
            if [[ "$clean_opt" =~ ^(–Э–∞–Ј–∞–і|–Ю—В–Љ–µ–љ–∞|–Т—Л—Е–Њ–і)$ ]]; then
                if [[ "$opt" != *$'\033'* ]]; then
                    opt="${YELLOW}${opt}${RESET}"
                fi
            fi
            
            # –°–і–µ–ї–∞–µ–Љ –≤—Б–µ –і–µ–є—Б—В–≤–Є—П "–£–і–∞–ї–Є—В—М" –Ї—А–∞—Б–љ—Л–Љ–Є
            if [[ "$clean_opt" == *"–£–і–∞–ї–Є—В—М"* ]]; then
                if [[ "$opt" != *$'\033'* ]]; then
                    opt="${RED}${opt}${RESET}"
                fi
            fi
            
            # –Т—Л—З–Є—Б–ї—П–µ–Љ –њ–∞–і–і–Є–љ–≥ –і–ї—П —Ж–µ–љ—В—А–Є—А–Њ–≤–∞–љ–Є—П –Є–ї–Є –ї–µ–≤–Њ–≥–Њ –≤—Л—А–∞–≤–љ–Є–≤–∞–љ–Є—П
            local padding_len=$(( max_len - ${#clean_opt} ))
            local text_to_draw=""
            
            if [[ "$clean_opt" =~ ^(–Э–∞–Ј–∞–і|–Ю—В–Љ–µ–љ–∞|–Т—Л—Е–Њ–і)$ ]]; then
                # –¶–µ–љ—В—А–Є—А—Г–µ–Љ —Н—В–Є –Ї–љ–Њ–њ–Ї–Є –≤–љ—Г—В—А–Є –Њ–±—Й–µ–є —И–Є—А–Є–љ—Л –Љ–µ–љ—О
                local pad_left=$(( padding_len / 2 ))
                local pad_right=$(( padding_len - pad_left ))
                local spaces_left=""
                local spaces_right=""
                [ $pad_left -gt 0 ] && spaces_left=$(printf "%${pad_left}s" "")
                [ $pad_right -gt 0 ] && spaces_right=$(printf "%${pad_right}s" "")
                
                if [ "$i" -eq "$active_idx" ]; then
                    text_to_draw="$spaces_left$clean_opt$spaces_right"
                    # –Ц–µ–ї—В—Л–є —Д–Њ–љ, —З–µ—А–љ—Л–є —В–µ–Ї—Б—В
                    printf "%${indent}s\033[43;30m  %b  \033[0m\033[K\n" "" "$text_to_draw"
                else
                    text_to_draw="$spaces_left$opt$spaces_right"
                    printf "%${indent}s  %b  \033[K\n" "" "$text_to_draw"
                fi
            else
                # –Ы–µ–≤–Њ–µ –≤—Л—А–∞–≤–љ–Є–≤–∞–љ–Є–µ –і–ї—П –Њ–±—Л—З–љ—Л—Е –њ—Г–љ–Ї—В–Њ–≤
                local padding=""
                [ $padding_len -gt 0 ] && padding=$(printf "%${padding_len}s" "")
                
                if [ "$i" -eq "$active_idx" ]; then
                    text_to_draw="$clean_opt$padding"
                    if [[ "$clean_opt" == *"–£–і–∞–ї–Є—В—М"* ]]; then
                        # –Ъ—А–∞—Б–љ—Л–є —Д–Њ–љ, —З–µ—А–љ—Л–є —В–µ–Ї—Б—В
                        printf "%${indent}s\033[41;30m  %b  \033[0m\033[K\n" "" "$text_to_draw"
                    else
                        # –°—В–∞–љ–і–∞—А—В–љ–∞—П –Є–љ–≤–µ—А—Б–Є—П (–±–µ–ї—Л–є/—Б–µ—А—Л–є —Д–Њ–љ, —З–µ—А–љ—Л–є —В–µ–Ї—Б—В)
                        printf "%${indent}s\033[7m  %b  \033[0m\033[K\n" "" "$text_to_draw"
                    fi
                else
                    text_to_draw="$opt$padding"
                    printf "%${indent}s  %b  \033[K\n" "" "$text_to_draw"
                fi
            fi
        done
        printf "\033[J" # –Ю—З–Є—Б—В–Є—В—М –≤—Б—С –љ–Є–ґ–µ –Љ–µ–љ—О
        
        # –Ю—В—А–Є—Б–Њ–≤–Ї–∞ —Б—В—А–Њ–Ї–Є –њ–Њ–і—Б–Ї–∞–Ј–Њ–Ї –≤ —Б–∞–Љ–Њ–Љ –љ–Є–Ј—Г —Н–Ї—А–∞–љ–∞ –±–µ–Ј –њ—А–Њ–Ї—А—Г—В–Ї–Є
        local term_height
        term_height=$(tput lines 2>/dev/null || echo 24)
        printf "\033[%d;1H\033[K" "$term_height"
        center_print_no_newline "${DIM}вЖСвЖУ вАФ –≤—Л–±–Њ—А   Enter вАФ –≤—Л–±—А–∞—В—М   q вАФ –љ–∞–Ј–∞–і   0 вАФ –Т—Л—Е–Њ–і${RESET}"
        
        # –°—З–Є—В—Л–≤–∞–љ–Є–µ –љ–∞–ґ–∞—В–Є—П –Ї–ї–∞–≤–Є—И–Є
        local key
        IFS= read -rsn1 key
        if [[ "$key" == $'\x1b' ]]; then
            local next_keys
            IFS= read -rsn2 -t 0.05 next_keys
            if [[ "$next_keys" == "[A" ]]; then # –Т–≤–µ—А—Е
                active_idx=$(( (active_idx - 1 + num_options) % num_options ))
            elif [[ "$next_keys" == "[B" ]]; then # –Т–љ–Є–Ј
                active_idx=$(( (active_idx + 1) % num_options ))
            fi
        elif [[ "$key" == "" ]]; then # Enter
            SELECTED_INDEX=$active_idx
            tput cnorm # –Я–Њ–Ї–∞–Ј–∞—В—М –Ї—Г—А—Б–Њ—А
            return 0
        elif [[ "$key" == "q" || "$key" == "Q" ]]; then
            SELECTED_INDEX=-1
            tput cnorm # –Я–Њ–Ї–∞–Ј–∞—В—М –Ї—Г—А—Б–Њ—А
            return 0
        elif [[ "$key" == "0" ]]; then
            clear_screen
            tput cnorm # –Я–Њ–Ї–∞–Ј–∞—В—М –Ї—Г—А—Б–Њ—А
            exit 0
        fi
    done
}

# вФАвФАвФА –У–Ы–Р–Т–Э–Ю–Х –Ь–Х–Э–Ѓ вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА

main_menu() {
    while true; do
        local options=(
            "–Я–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–Є"
            "–Э–∞—Б—В—А–Њ–є–Ї–Є"
            "–Ь–Њ–і—Г–ї–Є"
            "–Ф–Є–∞–≥–љ–Њ—Б—В–Є–Ї–∞"
            "–С—Н–Ї–∞–њ –Є –Т–Њ—Б—Б—В–∞–љ–Њ–≤–ї–µ–љ–Є–µ"
            "–Я–µ—А–µ–Ј–∞–њ—Г—Б—В–Є—В—М —Б–ї—Г–ґ–±—Л"
            "–Я–Њ–Ї–∞–Ј–∞—В—М –ї–Њ–≥–Є"
            "–Ь–Њ–љ–Є—В–Њ—А–Є–љ–≥ —А–µ—Б—Г—А—Б–Њ–≤"
            "–Т—Л—Е–Њ–і"
        )
        select_menu "TransferBox вАФ –Я–∞–љ–µ–ї—М –£–њ—А–∞–≤–ї–µ–љ–Є—П" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            users_menu
        elif [ "$choice" -eq 1 ]; then
            settings_menu
        elif [ "$choice" -eq 2 ]; then
            modules_menu
        elif [ "$choice" -eq 3 ]; then
            diagnostics_menu
        elif [ "$choice" -eq 4 ]; then
            backup_restore_menu
        elif [ "$choice" -eq 5 ]; then
            apply_settings_menu
        elif [ "$choice" -eq 6 ]; then
            logs_menu
        elif [ "$choice" -eq 7 ]; then
            system_monitor_menu
        elif [ "$choice" -eq 8 ] || [ "$choice" -eq -1 ]; then
            clear_screen
            exit 0
        fi
    done
}

