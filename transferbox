#!/usr/bin/env bash
# =============================================================================
# TransferBox вАФ –Я–∞–љ–µ–ї—М –£–њ—А–∞–≤–ї–µ–љ–Є—П (Pure Bash TUI —Б –љ–∞–≤–Є–≥–∞—Ж–Є–µ–є —Б—В—А–µ–ї–Ї–∞–Љ–Є)
