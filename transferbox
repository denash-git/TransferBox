#!/usr/bin/env bash
# =============================================================================
# TransferBox — Панель Управления (Pure Bash TUI с навигацией стрелками)
# =============================================================================
set -euo pipefail

# ANSI Colors
BLUE='\033[1;34m'
GREEN='\033[1;32m'
RED='\033[1;31m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

# Проверка запуска от root
if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo -e "${RED}Ошибка: Для запуска утилиты требуются права root. Используйте: sudo menu${RESET}" >&2
    exit 1
fi

PROJECT_ROOT="/opt/transferbox"
export PYTHONPATH="${PROJECT_ROOT}"

# ─── ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ─────────────────────────────────────────────────

clear_screen() {
    printf "\033[2J\033[H"
}

pause() {
    echo ""
    center_print "${DIM}Нажмите любую клавишу для продолжения...${RESET}"
    read -rsn1
}

read_prompt() {
    local prompt_text="$1"
    local var_name="$2"
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    local indent=$(( (term_width - 50) / 2 ))
    [ $indent -lt 2 ] && indent=2
    printf "%${indent}s%s" "" "$prompt_text"
    read -r "$var_name"
}

center_print() {
    local text="$1"
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    
    local clean_text
    clean_text=$(printf "%b" "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local text_len=${#clean_text}
    
    local padding=$(( (term_width - text_len) / 2 ))
    [ $padding -lt 0 ] && padding=0
    
    printf "%${padding}s%b\n" "" "$text"
}

center_print_no_newline() {
    local text="$1"
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    
    local clean_text
    clean_text=$(printf "%b" "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local text_len=${#clean_text}
    
    local padding=$(( (term_width - text_len) / 2 ))
    [ $padding -lt 0 ] && padding=0
    
    printf "%${padding}s%b" "" "$text"
}

draw_line() {
    local char="$1"
    local color="$2"
    local line
    line=$(printf "${char}%.0s" {1..60})
    center_print "${color}${line}${RESET}"
}

get_service_status() {
    local service_name="$1"
    if systemctl is-active "$service_name" >/dev/null 2>&1; then
        echo -e "${GREEN}● работает${RESET}"
    else
        local status
        status=$(systemctl is-active "$service_name" 2>/dev/null || echo "не установлен")
        echo -e "${RED}● не запущен ($status)${RESET}"
    fi
}

print_header() {
    local title="$1"
    local show_status="${2:-false}"
    local domain="не задан"
    if [ -f "/opt/transferbox/instance.env" ]; then
        domain=$(grep -E "^DOMAIN=" /opt/transferbox/instance.env | cut -d'=' -f2-)
    fi
    [ -z "$domain" ] && domain="не задан"
    
    local line_double
    line_double=$(printf "═%.0s" {1..60})
    local line_single
    line_single=$(printf "─%.0s" {1..60})
    
    center_print "${BLUE}${line_double}${RESET}"
    center_print "${YELLOW}${title}${RESET}"
    center_print "${BLUE}${line_single}${RESET}"
    if [ "$show_status" == "true" ]; then
        center_print "Домен: ${BOLD}${domain}${RESET}"
        center_print "Caddy: $(get_service_status caddy)"
        center_print "sing-box: $(get_service_status sing-box)"
        center_print "${BLUE}${line_double}${RESET}"
    fi
    echo ""
}

# Функция навигации стрелками
# Устанавливает переменную SELECTED_INDEX
select_menu() {
    local title="$1"
    shift
    local options=("$@")
    local num_options=${#options[@]}
    local active_idx=0
    
    # Скрыть курсор
    tput civis
    
    # Очистить экран один раз при входе в меню
    clear_screen
    
    while true; do
        # Переместить курсор в верхний левый угол
        printf "\033[H"
        
        # Определим, показывать ли статус на основе заголовка
        local show_status="false"
        if [ "$title" == "TransferBox — Панель Управления" ]; then
            show_status="true"
        fi
        
        print_header "$title" "$show_status"
        
        # Определим максимальную визуальную длину вариантов для центрирования блока
        local max_len=0
        for opt in "${options[@]}"; do
            local clean_opt
            clean_opt=$(printf "%b" "$opt" | sed 's/\x1b\[[0-9;]*m//g')
            if [ ${#clean_opt} -gt $max_len ]; then
                max_len=${#clean_opt}
            fi
        done
        
        local term_width
        term_width=$(tput cols 2>/dev/null || echo 80)
        local indent=$(( (term_width - max_len) / 2 ))
        [ $indent -lt 0 ] && indent=0
        
        for i in "${!options[@]}"; do
            if [ "$i" -eq "$active_idx" ]; then
                # Инверсия строки при выборе (код 7) с очисткой остатка строки \033[K
                printf "%${indent}s\033[7m  %b  \033[0m\033[K\n" "" "${options[$i]}"
            else
                printf "%${indent}s  %b  \033[K\n" "" "${options[$i]}"
            fi
        done
        printf "\033[J" # Очистить всё ниже меню
        
        # Отрисовка строки подсказок в самом низу экрана без прокрутки
        local term_height
        term_height=$(tput lines 2>/dev/null || echo 24)
        printf "\033[%d;1H\033[K" "$term_height"
        center_print_no_newline "${DIM}↑↓ — выбор   Enter — выбрать   q — назад   0 — Выход${RESET}"
        
        # Считывание нажатия клавиши
        local key
        IFS= read -rsn1 key
        if [[ "$key" == $'\x1b' ]]; then
            local next_keys
            IFS= read -rsn2 -t 0.05 next_keys
            if [[ "$next_keys" == "[A" ]]; then # Вверх
                active_idx=$(( (active_idx - 1 + num_options) % num_options ))
            elif [[ "$next_keys" == "[B" ]]; then # Вниз
                active_idx=$(( (active_idx + 1) % num_options ))
            fi
        elif [[ "$key" == "" ]]; then # Enter
            SELECTED_INDEX=$active_idx
            tput cnorm # Показать курсор
            return 0
        elif [[ "$key" == "q" || "$key" == "Q" || "$key" == "0" ]]; then
            SELECTED_INDEX=-1
            tput cnorm # Показать курсор
            return 1
        fi
    done
}

# ─── ГЛАВНОЕ МЕНЮ ────────────────────────────────────────────────────────────

main_menu() {
    while true; do
        local options=(
            "Пользователи"
            "Настройки"
            "Модули"
            "Диагностика"
            "Бэкап и Восстановление"
            "Перезапустить службы"
            "Показать логи"
            "Мониторинг ресурсов"
            "Выход"
        )
        select_menu "TransferBox — Панель Управления" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            users_menu
        elif [ "$choice" -eq 1 ]; then
            settings_menu
        elif [ "$choice" -eq 2 ]; then
            modules_menu
        elif [ "$choice" -eq 3 ]; then
            diagnostics_menu
        elif [ "$choice" -eq 4 ]; then
            backup_restore_menu
        elif [ "$choice" -eq 5 ]; then
            apply_settings_menu
        elif [ "$choice" -eq 6 ]; then
            logs_menu
        elif [ "$choice" -eq 7 ]; then
            system_monitor_menu
        elif [ "$choice" -eq 8 ] || [ "$choice" -eq -1 ]; then
            clear_screen
            exit 0
        fi
    done
}

# ─── МОДУЛИ ──────────────────────────────────────────────────────────────────

is_mieru_enabled() {
    local val
    val=$(grep -E "^MIERU_ENABLED=" /opt/transferbox/instance.env | cut -d'=' -f2- | tr -d '\r')
    [ "$val" == "true" ] && return 0
    return 1
}

modules_menu() {
    while true; do
        local mieru_status="${RED}отключен${RESET}"
        if is_mieru_enabled; then
            mieru_status="${GREEN}включен${RESET}"
        fi
        
        local options=(
            "Mieru (Статус: $mieru_status)"
            "Назад"
        )
        select_menu "Модули" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            mieru_module_menu
        elif [ "$choice" -eq 1 ] || [ "$choice" -eq -1 ]; then
            return
        fi
    done
}

mieru_module_menu() {
    while true; do
        local is_enabled
        is_enabled=$(grep -E "^MIERU_ENABLED=" /opt/transferbox/instance.env | cut -d'=' -f2- | tr -d '\r')
        [ -z "$is_enabled" ] && is_enabled="false"
        
        local status_label="${RED}отключен${RESET}"
        [ "$is_enabled" == "true" ] && status_label="${GREEN}включен${RESET}"
        
        local port
        port=$(grep -E "^MIERU_PORT=" /opt/transferbox/instance.env | cut -d'=' -f2- | tr -d '\r')
        [ -z "$port" ] && port="21000"
        
        local options=(
            "Включить / Выключить (Текущий статус: $status_label)"
            "Изменить порт (Текущий порт: $port)"
            "Назад"
        )
        select_menu "Модуль: Mieru" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            local new_status="true"
            [ "$is_enabled" == "true" ] && new_status="false"
            
            echo -e "\n  [*] Изменение статуса Mieru на $new_status..."
            python3 -c "
import os
env_path = '/opt/transferbox/instance.env'
lines = []
found = False
with open(env_path, 'r', encoding='utf-8') as f:
    for line in f:
        if line.startswith('MIERU_ENABLED='):
            lines.append('MIERU_ENABLED=$new_status\n')
            found = True
        else:
            lines.append(line)
if not found:
    lines.append('MIERU_ENABLED=$new_status\n')
with open(env_path, 'w', encoding='utf-8') as f:
    f.writelines(lines)
"
            # Ensure MIERU_PORT is also in env
            if ! grep -q "^MIERU_PORT=" /opt/transferbox/instance.env; then
                echo "MIERU_PORT=$port" >> /opt/transferbox/instance.env
            fi
            
            # Re-render configurations
            python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
            pause
        elif [ "$choice" -eq 1 ]; then
            local new_port
            read_prompt "Введите новый порт для Mieru (1024-65535, или 0 для отмены): " new_port
            if [ ! -z "$new_port" ] && [ "$new_port" != "0" ]; then
                if [[ "$new_port" =~ ^[0-9]+$ ]] && [ "$new_port" -ge 1024 ] && [ "$new_port" -le 65535 ]; then
                    echo -e "\n  [*] Изменение порта Mieru на $new_port..."
                    python3 -c "
import os
env_path = '/opt/transferbox/instance.env'
lines = []
found = False
with open(env_path, 'r', encoding='utf-8') as f:
    for line in f:
        if line.startswith('MIERU_PORT='):
            lines.append('MIERU_PORT=$new_port\n')
            found = True
        else:
            lines.append(line)
if not found:
    lines.append('MIERU_PORT=$new_port\n')
with open(env_path, 'w', encoding='utf-8') as f:
    f.writelines(lines)
"
                    python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
                    pause
                else
                    echo -e "\n  ${RED}✗ Неверный формат порта. Должно быть число от 1024 до 65535.${RESET}"
                    pause
                fi
            fi
        elif [ "$choice" -eq 2 ] || [ "$choice" -eq -1 ]; then
            return
        fi
    done
}

# ─── ДИАГНОСТИКА (SPEEDTEST) ──────────────────────────────────────────────────

diagnostics_menu() {
    while true; do
        local options=(
            "Тест VPS → Интернет (speedtest-cli)"
            "Замер скорости Client ↔ VPS (веб-страница)"
            "Показать текущий префикс speedtest"
            "Перегенерировать префикс speedtest"
            "Назад"
        )
        select_menu "Диагностика" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            run_speedtest_vps_internet
        elif [ "$choice" -eq 1 ]; then
            run_speedtest_client_vps
        elif [ "$choice" -eq 2 ]; then
            show_speedtest_prefix
        elif [ "$choice" -eq 3 ]; then
            regenerate_speedtest_prefix_menu
        elif [ "$choice" -eq 4 ] || [ "$choice" -eq -1 ]; then
            return
        fi
    done
}

run_speedtest_vps_internet() {
    # Check if official speedtest is installed, if not install it
    if ! dpkg -s speedtest >/dev/null 2>&1; then
        clear_screen
        print_header "Скорость VPS → Интернет" "false"
        echo -e "  [*] Установка официального Ookla Speedtest..."
        sudo apt-get purge -y speedtest-cli >/dev/null 2>&1 || true
        sudo apt-get install -f -y >/dev/null 2>&1 || true
        curl -s https://packagecloud.io/install/repositories/ookla/speedtest-cli/script.deb.sh | sudo bash >/dev/null 2>&1
        sudo apt-get install -y speedtest >/dev/null 2>&1
    fi

    if ! command -v speedtest >/dev/null 2>&1; then
        echo -e "  ${RED}✗ Не удалось установить speedtest.${RESET}"
        pause
        return
    fi

    while true; do
        local options=(
            "Тест на ближайшем сервере (автовыбор)"
            "Выбрать сервер из списка ближайших"
            "Назад"
        )
        select_menu "VPS → Интернет" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            clear_screen
            print_header "Скорость VPS → Интернет (Автовыбор)" "false"
            echo -e "  ${CYAN}Запуск теста, подождите...${RESET}\n"
            speedtest --accept-license --accept-gdpr 2>&1 | sed 's/^/  /'
            echo
            pause
            return
        elif [ "$choice" -eq 1 ]; then
            clear_screen
            print_header "Поиск ближайших серверов" "false"
            echo -e "  [*] Получение списка серверов..."
            
            local servers_raw=()
            while IFS= read -r line; do
                [ -z "$line" ] && continue
                if [[ "$line" =~ ^[[:space:]]*([0-9]+)[[:space:]]+(.*)$ ]]; then
                    servers_raw+=("${BASH_REMATCH[1]}|${BASH_REMATCH[2]}")
                fi
            done < <(speedtest -L --accept-license --accept-gdpr 2>/dev/null)
            
            if [ ${#servers_raw[@]} -eq 0 ]; then
                echo -e "\n  ${RED}✗ Не удалось получить список серверов.${RESET}"
                pause
                continue
            fi
            
            local select_opts=()
            local select_ids=()
            for s in "${servers_raw[@]}"; do
                IFS='|' read -r id details <<< "$s"
                details=$(echo "$details" | tr -s ' ')
                select_opts+=("[$id] $details")
                select_ids+=("$id")
            done
            select_opts+=("Назад")
            
            select_menu "Выберите сервер" "${select_opts[@]}"
            local sel_choice=$SELECTED_INDEX
            
            if [ "$sel_choice" -eq -1 ] || [ "$sel_choice" -eq $(( ${#select_opts[@]} - 1 )) ]; then
                continue
            fi
            
            local selected_id="${select_ids[$sel_choice]}"
            local selected_name="${select_opts[$sel_choice]}"
            
            clear_screen
            print_header "VPS → Интернет ($selected_name)" "false"
            echo -e "  ${CYAN}Запуск теста на сервере $selected_id, подождите...${RESET}\n"
            speedtest -s "$selected_id" --accept-license --accept-gdpr 2>&1 | sed 's/^/  /'
            echo
            pause
            return
        else
            return
        fi
    done
}

run_speedtest_client_vps() {
    clear_screen
    print_header "Замер скорости: Client ↔ VPS" "false"
    echo -e "  Временная HTTPS-ссылка на 10 минут для тестирования скорости."
    echo -e "  Откройте её в браузере для запуска замера (трафик идет по порту 443).\n"
    
    if ! systemctl is-active transferbox-speedtest --quiet 2>/dev/null; then
        echo -e "  [*] Запуск службы speedtest..."
        sudo systemctl start transferbox-speedtest >/dev/null 2>&1
    fi
    
    local token expires_at expires_human url domain prefix
    token=$(openssl rand -hex 12)
    expires_at=$(( $(date +%s) + 600 ))
    expires_human=$(date -d "@${expires_at}" '+%Y-%m-%d %H:%M:%S %Z' 2>/dev/null || date -u -d "@${expires_at}" '+%Y-%m-%d %H:%M:%S UTC')
    
    # Записываем в базу ссылок
    mkdir -p /opt/transferbox/backups
    printf '%s\t%s\t%s\n' "$token" "$expires_at" "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" >> /opt/transferbox/backups/speedtest-links.tsv
    chmod 600 /opt/transferbox/backups/speedtest-links.tsv
    
    domain=$(grep -E "^DOMAIN=" /opt/transferbox/instance.env | cut -d'=' -f2-)
    prefix=$(grep -E "^SPEEDTEST_PREFIX=" /opt/transferbox/instance.env | cut -d'=' -f2-)
    url="https://${domain}/${prefix}${token}/"
    
    echo -e "  ${YELLOW}Ссылка действует до:${RESET} ${CYAN}${expires_human}${RESET}\n"
    echo -e "  ${YELLOW}Ссылка:${RESET}"
    echo -e "  \033[1;36m${url}\033[0m\n"
    echo -e "  ${YELLOW}QR-код:${RESET}"
    qrencode -t ANSIUTF8 "${url}" 2>/dev/null || echo -e "  [qrencode не установлен]"
    echo
    pause
}

show_speedtest_prefix() {
    clear_screen
    print_header "Текущий префикс speedtest" "false"
    local prefix
    prefix=$(grep -E "^SPEEDTEST_PREFIX=" /opt/transferbox/instance.env | cut -d'=' -f2-)
    echo -e "  Текущий секретный префикс: ${GREEN}${prefix}${RESET}"
    echo -e "  Он используется для скрытия тестовой страницы от посторонних сканеров."
    echo
    pause
}

regenerate_speedtest_prefix_menu() {
    clear_screen
    print_header "Перегенерация префикса" "false"
    echo -e "  ${RED}⚠ Внимание: все ранее выданные ссылки speedtest перестанут работать!${RESET}"
    local confirm
    read_prompt "Вы действительно хотите сгенерировать новый префикс? [y/N]: " confirm
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
        local new_prefix
        new_prefix=$(openssl rand -hex 4)
        python3 -c "
import os
env_path = '/opt/transferbox/instance.env'
lines = []
with open(env_path, 'r', encoding='utf-8') as f:
    for line in f:
        if line.startswith('SPEEDTEST_PREFIX='):
            lines.append('SPEEDTEST_PREFIX=$new_prefix\n')
        else:
            lines.append(line)
with open(env_path, 'w', encoding='utf-8') as f:
    f.writelines(lines)
"
        echo -e "\n  [*] Перегенерация конфигураций..."
        python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
        echo -e "  ${GREEN}✓ Новый префикс успешно сохранен и применен!${RESET}"
        pause
    fi
}

# ─── МЕНЮ ПОЛЬЗОВАТЕЛЕЙ ──────────────────────────────────────────────────────

users_menu() {
    while true; do
        local options=(
            "Список пользователей"
            "Добавить нового пользователя"
            "Назад"
        )
        select_menu "Пользователи" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq 0 ]; then
            list_users_menu
        elif [ "$choice" -eq 1 ]; then
            create_user_menu
        elif [ "$choice" -eq 2 ] || [ "$choice" -eq -1 ]; then
            return
        fi
    done
}

list_users_menu() {
    while true; do
        if [ ! -f "/opt/transferbox/users.json" ] || [ "$(jq '. | length' /opt/transferbox/users.json 2>/dev/null)" -eq 0 ]; then
            clear_screen
            print_header "Список пользователей"
            echo -e "  Пользователей пока нет."
            pause
            return
        fi
        
        # Считывание уникальных пользователей и списка их протоколов
        local users_raw=()
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            users_raw+=("$line")
        done < <(jq -r 'group_by(.nickname)[] | "\((.[0].nickname))|\(map(if .protocol == "naive" then "Naive" else "VLESS " + (if .credentials.type == "ws" then "WS" else if .credentials.type == "grpc" then "gRPC" else if .credentials.type == "xhttp" then "XHTTP" else .credentials.type end end end) end) | join(", "))"' /opt/transferbox/users.json 2>/dev/null)
        
        local options=()
        local nicknames=()
        local max_nick_len=0
        
        for u in "${users_raw[@]}"; do
            IFS='|' read -r nick protos <<< "$u"
            nicknames+=("$nick")
            if [ ${#nick} -gt $max_nick_len ]; then
                max_nick_len=${#nick}
            fi
        done
        
        local col_width=$(( max_nick_len + 4 ))
        for u in "${users_raw[@]}"; do
            IFS='|' read -r nick protos <<< "$u"
            local pad_spaces=""
            local pad_len=$(( col_width - ${#nick} ))
            if [ $pad_len -gt 0 ]; then
                pad_spaces=$(printf "%${pad_len}s" "")
            fi
            options+=("$nick$pad_spaces(Протоколы: $protos)")
        done
        options+=("Назад")
        
        select_menu "Список пользователей" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq -1 ] || [ "$choice" -eq $(( ${#options[@]} - 1 )) ]; then
            return
        else
            local selected_nick="${nicknames[$choice]}"
            user_management_menu "$selected_nick"
        fi
    done
}

user_management_menu() {
    local nick="$1"
    while true; do
        # Проверяем, существует ли еще пользователь
        if ! jq -e ".[] | select(.nickname == \"$nick\")" /opt/transferbox/users.json >/dev/null 2>&1; then
            return
        fi
        
        # Загружаем протоколы этого пользователя
        local protocols_raw=()
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            protocols_raw+=("$line")
        done < <(jq -r ".[] | select(.nickname == \"$nick\") | \"\(.protocol)|\(.credentials.type // \"\")|\(.enabled)\"" /opt/transferbox/users.json 2>/dev/null)
        
        local options=()
        local proto_types=()
        local proto_labels=()
        
        for p in "${protocols_raw[@]}"; do
            IFS='|' read -r proto utype enabled <<< "$p"
            local label=""
            if [ "$proto" == "naive" ]; then
                label="NaiveProxy"
            elif [ "$proto" == "mieru" ]; then
                label="Mieru"
            else
                label="VLESS over ${utype^^}"
            fi
            proto_labels+=("$label")
            proto_types+=("$proto|$utype|$enabled")
            
            local status_str="${RED}отключен${RESET}"
            [ "$enabled" == "true" ] && status_str="${GREEN}активен${RESET}"
            options+=("• $label [$status_str]")
        done
        
        local num_protocols=${#options[@]}
        
        options+=("[+] Добавить протокол")
        options+=("[i] Ссылка подписки & QR")
        options+=("[x] Удалить пользователя полностью")
        options+=("Назад")
        
        select_menu "Управление: $nick" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq -1 ] || [ "$choice" -eq $(( ${#options[@]} - 1 )) ]; then
            return
        elif [ "$choice" -lt "$num_protocols" ]; then
            local selected_proto="${proto_types[$choice]}"
            local selected_label="${proto_labels[$choice]}"
            IFS='|' read -r proto utype enabled <<< "$selected_proto"
            protocol_management_menu "$nick" "$proto" "$utype" "$enabled" "$selected_label"
        elif [ "$choice" -eq "$num_protocols" ]; then
            add_protocol_to_user "$nick"
        elif [ "$choice" -eq $(( num_protocols + 1 )) ]; then
            show_subscription_qr "$nick"
        elif [ "$choice" -eq $(( num_protocols + 2 )) ]; then
            local confirm
            read_prompt "Вы действительно хотите полностью удалить пользователя $nick и все его протоколы? [y/N]: " confirm
            if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                echo -e "\n  [*] Удаление пользователя..."
                python3 -c "
from core.user_manager import delete_user
success, msg = delete_user('$nick')
print(msg)
"
                python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
                pause
                return
            fi
        fi
    done
}

protocol_management_menu() {
    local nick="$1"
    local proto="$2"
    local utype="$3"
    local enabled="$4"
    local label="$5"
    
    while true; do
        # Проверяем существование этого конкретного протокола
        if [ "$proto" == "naive" ]; then
            if ! jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"naive\")" /opt/transferbox/users.json >/dev/null 2>&1; then
                return
            fi
        else
            if ! jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"$proto\" and .credentials.type == \"$utype\")" /opt/transferbox/users.json >/dev/null 2>&1; then
                return
            fi
        fi
        
        # Получаем актуальный статус из базы
        enabled=$(jq -r ".[] | select(.nickname == \"$nick\" and .protocol == \"$proto\" and (.credentials.type // \"\") == \"$utype\") | .enabled" /opt/transferbox/users.json)
        
        local status_label="${GREEN}активен${RESET}"
        if [ "$enabled" != "true" ]; then
            status_label="${RED}отключен${RESET}"
        fi
        
        local options=(
            "Включить / Выключить (Статус: $status_label)"
            "Показать ссылку подключения и QR-код"
            "Удалить этот протокол"
            "Назад"
        )
        select_menu "$nick ($label)" "${options[@]}"
        local choice=$SELECTED_INDEX
        
        if [ "$choice" -eq -1 ] || [ "$choice" -eq 3 ]; then
            return
        elif [ "$choice" -eq 0 ]; then
            local new_status="True"
            if [ "$enabled" == "true" ]; then
                new_status="False"
            fi
            echo -e "\n  [*] Изменение статуса протокола..."
            python3 -c "
from core.user_manager import toggle_user
success, msg = toggle_user('$nick', $new_status, '$proto', '$utype')
print(msg)
"
            python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
            pause
        elif [ "$choice" -eq 1 ]; then
            clear_screen
            local link
            link=$(python3 -c "
from core.config_manager import load_users, build_client_link
users = load_users()
user = next((u for u in users if u['nickname'] == '$nick' and u['protocol'] == '$proto' and u.get('credentials', {}).get('type', '') == '$utype'), None)
if user:
    print(build_client_link(user))
")
            print_header "Подключение: $nick ($label)" "false"
            if [ "$proto" == "mieru" ]; then
                echo -e "  JSON-конфигурация подключения (скопируйте её целиком):"
                echo -e "${CYAN}$link${RESET}"
            else
                echo -e "  Ссылка подключения:"
                echo -e "  \033[1;36m$link\033[0m"
            fi
            echo -e "\n  QR-код:"
            qrencode -t ANSIUTF8 "$link" 2>/dev/null || echo -e "  [qrencode не установлен на сервере]"
            pause
        elif [ "$choice" -eq 2 ]; then
            local confirm
            read_prompt "Вы действительно хотите удалить протокол $label для $nick? [y/N]: " confirm
            if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                echo -e "\n  [*] Удаление протокола..."
                python3 -c "
from core.user_manager import delete_user
success, msg = delete_user('$nick', '$proto', '$utype')
print(msg)
"
                python3 -c "
from core.config_manager import render_configs, validate_and_restart
render_configs()
validate_and_restart()
"
                pause
                return
            fi
        fi
    done
}

