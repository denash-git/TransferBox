add_protocol_to_user() {
    local nick="$1"
    
    local has_ws=false
    local has_grpc=false
    local has_xhttp=false
    local has_naive=false
    local has_mieru=false
    
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"vless\" and .credentials.type == \"ws\")" /opt/transferbox/users.json >/dev/null 2>&1; then
        has_ws=true
    fi
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"vless\" and .credentials.type == \"grpc\")" /opt/transferbox/users.json >/dev/null 2>&1; then
        has_grpc=true
