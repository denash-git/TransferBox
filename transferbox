    echo -e "\n  –Ґ–µ–Ї—Г—Й–∞—П —Г—Б—В–∞–љ–Њ–≤–ї–µ–љ–љ–∞—П –≤–µ—А—Б–Є—П: ${BOLD}$current${RESET}"
