                tput cnorm
                return 0
            fi
        fi
        
        # –°—З–Є—В—Л–≤–∞–љ–Є–µ CPU stats 2
        local cpu_stat2
        cpu_stat2=$(grep '^cpu ' /proc/stat)
        local stats2=($cpu_stat2)
