add_protocol_to_user() {
    local nick="$1"
    
    local has_ws=false
    local has_grpc=false
    local has_xhttp=false
    local has_naive=false
    local has_mieru=false
    
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"vless\" and .credentials.type == \"ws\")" ${PROJECT_ROOT}/users.json >/dev/null 2>&1; then
        has_ws=true
    fi
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"vless\" and .credentials.type == \"grpc\")" ${PROJECT_ROOT}/users.json >/dev/null 2>&1; then
        has_grpc=true
    fi
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"vless\" and .credentials.type == \"xhttp\")" ${PROJECT_ROOT}/users.json >/dev/null 2>&1; then
        has_xhttp=true
    fi
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"naive\")" ${PROJECT_ROOT}/users.json >/dev/null 2>&1; then
        has_naive=true
    fi
    if jq -e ".[] | select(.nickname == \"$nick\" and .protocol == \"mieru\")" ${PROJECT_ROOT}/users.json >/dev/null 2>&1; then
        has_mieru=true
    fi

    local options=()
