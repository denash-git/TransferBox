system_monitor_menu() {
    # Скрыть курсор
    tput civis
    clear_screen
    
    # Найти главный сетевой интерфейс
    local iface
    iface=$(ip route | grep default | awk '{print $5}' | head -n 1)
    [ -z "$iface" ] && iface="eth0"
    
    while true; do
        # Считывание CPU stats 1
        local cpu_stat1
        cpu_stat1=$(grep '^cpu ' /proc/stat)
        local stats1=($cpu_stat1)
        local idle1=${stats1[4]}
        local total1=0
        for val in "${stats1[@]:1}"; do total1=$(( total1 + val )); done
        
        # Считывание Net stats 1
        local net1
        net1=$(grep "$iface:" /proc/net/dev | awk '{print $2 " " $10}' || echo "0 0")
        local rx1
        rx1=$(echo "$net1" | awk '{print $1}')
        local tx1
        tx1=$(echo "$net1" | awk '{print $2}')
        
        # Ожидание 1 секунды и считывание клавиши
        local key=""
        if read -t 1 -rsn1 key; then
            if [[ "$key" == "q" || "$key" == "Q" || "$key" == "0" || "$key" == "" ]]; then
                tput cnorm
                return
            fi
        fi
        
        # Считывание CPU stats 2
        local cpu_stat2
        cpu_stat2=$(grep '^cpu ' /proc/stat)
        local stats2=($cpu_stat2)
        local idle2=${stats2[4]}
        local total2=0
        for val in "${stats2[@]:1}"; do total2=$(( total2 + val )); done
        
        # Считывание Net stats 2
        local net2
        net2=$(grep "$iface:" /proc/net/dev | awk '{print $2 " " $10}' || echo "0 0")
        local rx2
        rx2=$(echo "$net2" | awk '{print $1}')
        local tx2
        tx2=$(echo "$net2" | awk '{print $2}')
        
        # Расчет CPU
        local diff_idle=$(( idle2 - idle1 ))
        local diff_total=$(( total2 - total1 ))
        local cpu_pct=0
        if [ $diff_total -gt 0 ]; then
            cpu_pct=$(( (diff_total - diff_idle) * 100 / diff_total ))
        fi
        
        # Расчет скорости сети
        local rx_speed=$(( (rx2 - rx1) / 1024 ))
        local tx_speed=$(( (tx2 - tx1) / 1024 ))
        
        # Расчет RAM
        local ram_total
        ram_total=$(free -m | awk '/Mem:/ {print $2}')
        local ram_used
        ram_used=$(free -m | awk '/Mem:/ {print $3}')
        local ram_pct=$(( ram_used * 100 / ram_total ))
        
        # Расчет Диска
        local disk_total
        disk_total=$(df -h / | awk 'NR==2 {print $2}')
        local disk_used
        disk_used=$(df -h / | awk 'NR==2 {print $3}')
        local disk_pct
        disk_pct=$(df -h / | awk 'NR==2 {print $5}')
        
        # Форматирование скорости сети
        local rx_str="${rx_speed} KB/s"
        if [ $rx_speed -gt 1024 ]; then
            rx_str=$(echo "scale=1; $rx_speed / 1024" | bc 2>/dev/null || echo "$(( rx_speed / 1024 ))")
            rx_str="${rx_str} MB/s"
        fi
        local tx_str="${tx_speed} KB/s"
        if [ $tx_speed -gt 1024 ]; then
            tx_str=$(echo "scale=1; $tx_speed / 1024" | bc 2>/dev/null || echo "$(( tx_speed / 1024 ))")
            tx_str="${tx_str} MB/s"
        fi
        
        # Отрисовка TUI
        printf "\033[H"
        print_header "Мониторинг ресурсов" "false"
        
        center_print "Загрузка процессора (CPU):"
        center_print "${BOLD}${cpu_pct}%${RESET}"
        echo ""
        center_print "Использование памяти (RAM):"
        center_print "${BOLD}${ram_used} Мб / ${ram_total} Мб (${ram_pct}%)${RESET}"
        echo ""
        center_print "Занятость диска (Disk):"
        center_print "${BOLD}${disk_used} / ${disk_total} (${disk_pct})${RESET}"
        echo ""
        center_print "Скорость сети (Interface: $iface):"
        center_print "Скачивание (RX): ${BOLD}${rx_str}${RESET}  |  Отдача (TX): ${BOLD}${tx_str}${RESET}"
        
        echo ""
        draw_line "─" "$BLUE"
        center_print "${DIM}[Нажмите Q или Enter для возврата в меню]${RESET}"
        printf "\033[J"
    done
}

